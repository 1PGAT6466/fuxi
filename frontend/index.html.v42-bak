<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>伏羲 4.2 · 外探</title>
<style>
:root {
  --bg: #0a0a0f;
  --bg-card: #12121a;
  --border: rgba(212,168,67,0.12);
  --border-active: rgba(212,168,67,0.35);
  --gold: #d4a843;
  --gold-dim: rgba(212,168,67,0.5);
  --text: #c8c4b8;
  --text2: #8a8478;
  --text-dim: #5a5548;
  --wood: #4a9e6e;
  --fire: #c2593a;
  --earth: #c4a45a;
  --metal: #d4c5b9;
  --water: #3a5070;
  --radius: 12px;
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:"Microsoft YaHei","PingFang SC",system-ui,sans-serif;min-height:100vh}
a{color:inherit;text-decoration:none}
/* ===== 导航条 ===== */
.nav{display:flex;align-items:center;padding:12px 24px;border-bottom:1px solid var(--border);gap:24px;background:#0d0d15;position:sticky;top:0;z-index:10}
.nav-brand{font-size:18px;color:var(--gold);letter-spacing:.06em;display:flex;align-items:center;gap:8px}
.nav-brand .bagua-ring{display:inline-block;width:24px;height:24px;border:1px solid var(--gold-dim);border-radius:50%;position:relative;animation:spin-slow 24s linear infinite}
.nav-brand .bagua-ring::after{content:'☰';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:10px;color:var(--gold);font-family:"SimSun",serif}
.nav-links{display:flex;gap:20px;margin-left:auto;align-items:center}
.nav-links a{font-size:13px;color:var(--text2);padding:6px 12px;border-radius:6px;transition:.2s}
.nav-links a:hover{color:var(--gold);background:rgba(212,168,67,0.08)}
.nav-stem{font-size:11px;color:var(--gold-dim);border:1px solid var(--border);border-radius:20px;padding:3px 10px}
@keyframes spin-slow{to{transform:rotate(360deg)}}
/* ===== Hero ===== */
.hero{text-align:center;padding:48px 24px 32px}
.hero h1{font-size:32px;color:var(--gold);letter-spacing:.1em;font-weight:300}
.hero p{font-size:14px;color:var(--text2);margin-top:8px}
.search-box{margin:28px auto 0;max-width:600px;position:relative}
.search-box textarea{width:100%;padding:14px 48px 14px 20px;background:var(--bg-card);border:1px solid var(--border);border-radius:30px;color:var(--text);font-size:15px;resize:none;outline:none;font-family:inherit;min-height:48px}
.search-box textarea:focus{border-color:var(--border-active);box-shadow:0 0 20px rgba(212,168,67,0.08)}
.search-box .send-btn{position:absolute;right:6px;bottom:6px;width:36px;height:36px;border-radius:50%;background:var(--gold-dim);border:none;color:var(--bg);font-size:16px;cursor:pointer;transition:.2s}
.search-box .send-btn:hover{background:var(--gold)}
/* 快捷提示 */
.hints{display:flex;flex-wrap:wrap;justify-content:center;gap:8px;margin-top:16px}
.hint{padding:6px 16px;font-size:12px;color:var(--text2);background:var(--bg-card);border:1px solid var(--border);border-radius:20px;cursor:pointer;transition:.2s}
.hint:hover{border-color:var(--border-active);color:var(--gold)}
/* ===== 脉象条 ===== */
.pulse-bar{display:flex;justify-content:center;align-items:center;gap:4px;padding:8px 24px;background:var(--bg-card);border-top:1px solid var(--border);border-bottom:1px solid var(--border);font-size:11px;color:var(--text2)}
.pulse-bar .wx-dot{width:6px;height:6px;border-radius:50%;display:inline-block}
.pulse-bar .wx-dot.metal{background:var(--metal)}
.pulse-bar .wx-dot.wood{background:var(--wood)}
.pulse-bar .wx-dot.water{background:var(--water)}
.pulse-bar .wx-dot.fire{background:var(--fire)}
.pulse-bar .wx-dot.earth{background:var(--earth)}
/* ===== 结果区 ===== */
.results{max-width:800px;margin:0 auto;padding:24px}
.chat-msg{margin-bottom:20px;animation:fadeIn .4s}
.chat-q{background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:16px 20px;margin-bottom:8px;font-size:14px}
.chat-a{background:transparent;border:1px solid var(--border);border-radius:var(--radius);padding:16px 20px;line-height:1.8;font-size:14px}
.chat-a p{margin-bottom:8px}
.chat-a h3,.chat-a h4{color:var(--gold);margin:12px 0 6px}
.chat-a ul{padding-left:20px;margin:4px 0}
.chat-a code{background:#1a1a28;padding:2px 6px;border-radius:4px;font-size:13px}
.source-tag{font-size:10px;color:var(--gold-dim);margin-top:8px;display:flex;gap:8px;flex-wrap:wrap}
.source-tag span{padding:2px 8px;border:1px solid var(--border);border-radius:10px;cursor:pointer}
.source-tag span:hover{border-color:var(--gold-dim)}
.antenna-tag{font-size:11px;color:var(--fire);display:inline-flex;align-items:center;gap:4px;margin-left:8px;animaton:pulse-gold 2s infinite}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
@keyframes pulse-gold{0%,100%{opacity:1}50%{opacity:.5}}
.empty-state{text-align:center;padding:60px 24px;color:var(--text-dim)}
/* ===== 底部快捷区 ===== */
.quick-nav{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;max-width:800px;margin:0 auto 40px;padding:0 24px}
.qn-card{background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:20px;text-align:center;cursor:pointer;transition:.25s}
.qn-card:hover{border-color:var(--border-active);background:#1a1a28}
.qn-card .qn-icon{font-size:28px;color:var(--gold);margin-bottom:8px;display:block}
.qn-card .qn-title{font-size:14px;color:var(--text)}
.qn-card .qn-desc{font-size:11px;color:var(--text-dim);margin-top:4px}
@media(max-width:600px){.quick-nav{grid-template-columns:1fr 1fr}}
</style>
</head>
<body>

<nav class="nav">
  <div class="nav-brand">
    <span class="bagua-ring"></span>
    伏羲 4.2
  </div>
  <div class="nav-links">
    <a href="/admin" target="_blank">内世界</a>
    <span class="nav-stem" id="navStem">—</span>
  </div>
</nav>

<div class="hero">
  <h1>外探 · 求知</h1>
  <p>以内世界之力，向外投射，触达未知</p>
  <div class="search-box">
    <textarea id="searchInput" placeholder="探索企业知识…" rows="1" onkeydown="if(event.key==='Enter'){event.preventDefault();search()}"></textarea>
    <button class="send-btn" onclick="search()">➤</button>
  </div>
  <div class="hints">
    <span class="hint" onclick="quickSearch('RAG 分块策略')">🔍 RAG 分块策略</span>
    <span class="hint" onclick="quickSearch('PA66 材料参数')">🧱 PA66 材料参数</span>
    <span class="hint" onclick="quickSearch('VLAN 配置方法')">🌐 VLAN 配置方法</span>
    <span class="hint" onclick="quickSearch('自动化产线设计')">🏭 自动化产线设计</span>
    <span class="hint" onclick="quickSearch('轴承选型标准')">⚙️ 轴承选型标准</span>
  </div>
</div>

<div class="pulse-bar" id="pulseBar">
  脉象：<span id="pulseHealth">检测中…</span>
</div>

<div class="quick-nav">
  <div class="qn-card" onclick="window.open('/admin','_blank')">
    <span class="qn-icon">☰</span>
    <span class="qn-title">内世界</span>
    <span class="qn-desc">九宫诊断 · 五行生克</span>
  </div>
  <div class="qn-card" onclick="alert('Wiki 浏览功能')">
    <span class="qn-icon">☷</span>
    <span class="qn-title">坤藏</span>
    <span class="qn-desc">结构化知识仓储</span>
  </div>
  <div class="qn-card" onclick="alert('文件管理功能')">
    <span class="qn-icon">☵</span>
    <span class="qn-title">坎渊</span>
    <span class="qn-desc">原始文档精炼池</span>
  </div>
</div>

<div class="results" id="results">
  <div class="empty-state">
    <div style="font-size:48px;color:var(--gold-dim);margin-bottom:12px">☰</div>
    <p>以内探外，格物致知</p>
  </div>
</div>

<script>
let _chatHistory = [];

async function search() {
  const input = document.getElementById('searchInput');
  const q = input.value.trim();
  if (!q) return;
  input.value = '';
  _chatHistory.push({role:'user',content:q});

  const results = document.getElementById('results');
  const qDiv = document.createElement('div'); qDiv.className='chat-q'; qDiv.textContent = q;
  results.insertBefore(qDiv, results.firstChild);

  const aDiv = document.createElement('div'); aDiv.className='chat-a'; aDiv.innerHTML = '<em>⚡ 探询中…</em>';
  results.insertBefore(aDiv, results.firstChild);

  try {
    const resp = await fetch('/api/chat', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({question:q, mode:'ai', filter:'all', history:_chatHistory.slice(-5)})
    });
    const data = await resp.json();
    const answer = data.answer || '未得回应。';
    let html = answer.replace(/\n\n/g, '</p><p>').replace(/\n/g, '<br>');
    html = '<p>' + html.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>') + '</p>';

    // 来源标签
    let srcTags = '';
    if (data.sources && data.sources.length > 0) {
      srcTags = '<div class="source-tag">' + data.sources.slice(0,5).map(s =>
        `<span onclick="window.open('${escapeHtml(s.url||'#')}','_blank')" title="${escapeHtml(s.file_name||'')}">📎 ${escapeHtml((s.file_name||s.title||'').substring(0,30))}</span>`
      ).join('') + '</div>';
    }

    // 触角外探标签
    let antennaTag = '';
    if (data.mode && data.mode.includes('antenna')) {
      antennaTag = '<span class="antenna-tag">☲ 触角·外探</span>';
    }

    aDiv.innerHTML = html + srcTags + antennaTag;
    _chatHistory.push({role:'assistant',content:answer});
  } catch(e) {
    aDiv.innerHTML = '<em style="color:var(--fire)">⚡ 触角未及，请重试…</em>';
  }
}

function quickSearch(q) {
  document.getElementById('searchInput').value = q;
  search();
}

function escapeHtml(s) { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

async function checkPulse() {
  try {
    const r = await fetch('/api/v2/status');
    const d = await r.json();
    if (!d.ok) return;
    document.getElementById('pulseHealth').textContent = `${d.health_score||'—'} · ${d.alive_organs||'—'}/${d.total_organs||'—'} 脉通`;
    const bal = d.balance || {};
    const stem = (bal.stem_scheduler || {}).current_stem || '—';
    const el = {甲:'木',乙:'木',丙:'火',丁:'火',戊:'土',己:'土',庚:'金',辛:'金',壬:'水',癸:'水'}[stem]||'';
    document.getElementById('navStem').textContent = `${stem} · ${el}`;
  } catch(e){}
}

checkPulse();
setInterval(checkPulse, 30000);
</script>
</body>
</html>
