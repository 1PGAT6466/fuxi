<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>☰ 伏羲 · 八卦台 · 真皮层</title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><rect width='64' height='64' rx='14' fill='%23f7f3ec'/><text x='32' y='46' text-anchor='middle' font-size='38' font-weight='bold' fill='%23b5342e'>☰</text></svg>">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700&family=Noto+Serif+SC:wght@700;900&display=swap" rel="stylesheet">
<style>/* ☰ 伏羲 V5 · 真皮层 */
:root {
  --paper: #f7f3ec; --card: #fcfaf6; --warm: #f0ebe0;
  --cin: #b5342e; --cin-light: #d4463b; --cin-glow: rgba(181,52,46,.08);
  --ink: #1a1512; --ink-mid: #3d3732; --ink-soft: #6b645b; --ink-faint: #9a9288;
  --jade: #4a8c5c; --jade-bg: #e8f5e9; --amber: #c7842d; --coral: #c9433a;
  --border: #e5ded3; --border-light: #efebe4;
  --shadow: 0 1px 3px rgba(26,21,18,.04);
  --shadow-md: 0 4px 16px rgba(26,21,18,.06);
  --serif: 'Noto Serif SC','SimSun',serif;
  --sans: 'Noto Sans SC','PingFang SC','Microsoft YaHei',sans-serif;
  --mono: 'JetBrains Mono','Cascadia Code',monospace;
  --ease: cubic-bezier(.16,1,.3,1);
  --radius: 8px; --radius-md: 12px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--sans);background:var(--paper);color:var(--ink-mid);line-height:1.7;-webkit-font-smoothing:antialiased}
a{color:var(--cin);text-decoration:none}

/* ===== 侧边栏 ===== */
.sidebar{position:fixed;left:0;top:0;bottom:0;width:220px;background:var(--card);border-right:1px solid var(--border);display:flex;flex-direction:column;z-index:100}
.sidebar-brand{padding:20px;font-family:var(--serif);font-size:1rem;font-weight:900;color:var(--cin);display:flex;align-items:center;gap:8px;border-bottom:1px solid var(--border);letter-spacing:.04em}
.nav-divider{padding:16px 20px 6px;font-size:.625rem;color:var(--ink-faint);text-transform:uppercase;letter-spacing:.1em;font-weight:700}
.sidebar-nav{flex:1;overflow-y:auto;padding:8px 0}
.sidebar-footer{padding:12px 16px;border-top:1px solid var(--border);font-size:.6875rem;color:var(--ink-faint)}
.nav-item{display:flex;align-items:center;gap:10px;padding:10px 20px;font-size:.8125rem;color:var(--ink-soft);cursor:pointer;transition:all .15s var(--ease);border-left:3px solid transparent;font-weight:500;background:none;border-top:none;border-right:none;border-bottom:none;width:100%;text-align:left;font-family:var(--sans)}
.nav-item:hover{background:var(--warm);color:var(--ink)}
.nav-item.active{background:var(--cin-glow);color:var(--cin);border-left-color:var(--cin);font-weight:700}
.status-dot{width:6px;height:6px;border-radius:50%;background:var(--jade);display:inline-block}
.status-dot.off{background:var(--coral)}

/* ===== 主区域 ===== */
.main{margin-left:220px;padding:24px 32px;max-width:1280px;min-height:100vh}
.topbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px}
.topbar-title{font-family:var(--serif);font-size:1.25rem;font-weight:900;color:var(--ink)}
.page{display:none}.page.active{display:block}

/* ===== 器官诊断面板 ===== */
.organ-flow{display:flex;flex-direction:column;gap:8px;margin-bottom:28px}
.organ-card{display:flex;align-items:center;gap:12px;background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:14px 18px;transition:all .3s var(--ease)}
.organ-card:hover{box-shadow:var(--shadow-md)}
.organ-card.alive{border-left:4px solid var(--jade)}
.organ-card.dead{border-left:4px solid var(--coral);opacity:.7}
.organ-icon{font-size:1.5rem;width:44px;height:44px;display:flex;align-items:center;justify-content:center;background:var(--warm);border-radius:50%;flex-shrink:0}
.organ-info{flex:1;min-width:0}
.organ-name{font-weight:700;font-size:.875rem;color:var(--ink)}
.organ-nature{font-size:.625rem;color:var(--ink-faint);text-transform:uppercase;letter-spacing:.06em}
.organ-meta{display:flex;gap:18px;font-size:.6875rem;color:var(--ink-soft);margin-top:2px}
.organ-status{font-size:.6875rem;font-weight:700;padding:4px 10px;border-radius:12px;flex-shrink:0}
.organ-status.healthy{background:var(--jade-bg);color:var(--jade)}
.organ-status.warning{background:#fef7e8;color:var(--amber)}
.organ-status.dead{background:#fef2f0;color:var(--coral)}
.organ-flow-arrow{text-align:center;color:var(--ink-faint);font-size:.625rem;padding:2px 0 2px 52px}

/* ===== 经络监控面板 ===== */
.panel-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px;margin-bottom:28px}
.panel{background:var(--card);border:1px solid var(--border);border-radius:var(--radius-md);padding:20px 24px}
.panel-title{font-family:var(--serif);font-size:.9375rem;font-weight:700;color:var(--ink);margin-bottom:16px;display:flex;align-items:center;gap:8px}
.panel-stat{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border-light)}
.panel-stat:last-child{border-bottom:none}
.panel-stat-label{font-size:.75rem;color:var(--ink-soft)}
.panel-stat-value{font-family:var(--mono);font-size:.875rem;font-weight:700;color:var(--ink)}
.panel-stat-value.high{color:var(--cin)}

/* 信号脉冲 */
@keyframes signalPulse{0%,100%{box-shadow:0 0 0 0 var(--cin-glow)}50%{box-shadow:0 0 0 6px transparent}}
.signal-live{display:flex;align-items:center;gap:8px;margin-top:12px;padding:8px 12px;background:var(--warm);border-radius:var(--radius);font-size:.75rem;color:var(--ink-soft)}
.signal-live-dot{width:8px;height:8px;border-radius:50%;background:var(--jade);animation:signalPulse 2s ease-in-out infinite}

/* ===== 运维工具页 ===== */
.func-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px}
.func-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius-md);padding:20px 24px;cursor:pointer;transition:all .25s var(--ease)}
.func-card:hover{border-color:var(--cin);box-shadow:var(--shadow-md);transform:translateY(-2px)}
.func-card-title{font-weight:700;font-size:.875rem;color:var(--ink);margin-bottom:4px}
.func-card-desc{font-size:.75rem;color:var(--ink-soft);line-height:1.6}
.func-card-icon{font-size:1.5rem;margin-bottom:10px}

/* 系统状态2x4 */
.quick-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:24px}
.stat-chip{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px;text-align:center}
.stat-chip:hover{border-color:var(--cin)}
.sc-val{font-family:var(--serif);font-size:1.35rem;font-weight:900;color:var(--ink)}
.sc-label{font-size:.625rem;color:var(--ink-faint);text-transform:uppercase;letter-spacing:.06em;margin-top:2px}

/* 文件管理 */
.file-header{display:flex;align-items:center;gap:12px;margin-bottom:16px;flex-wrap:wrap}
.file-header input{flex:1;min-width:200px;max-width:400px;padding:10px 14px;border:2px solid var(--border);border-radius:var(--radius);font-family:var(--sans);font-size:.875rem;background:var(--card);color:var(--ink);outline:none;transition:all .3s}
.file-header input:focus{border-color:var(--cin);box-shadow:0 0 0 4px var(--cin-glow)}
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:6px;font-size:.75rem;font-weight:600;cursor:pointer;border:none;transition:all .15s var(--ease);font-family:var(--sans)}
.btn-pri{background:var(--cin);color:#fff}.btn-pri:hover{background:var(--cin-light)}
.btn-out{background:transparent;color:var(--ink-soft);border:1px solid var(--border)}.btn-out:hover{border-color:var(--cin);color:var(--cin)}
.file-table{width:100%;border-collapse:collapse;font-size:.8125rem}
.file-table th{text-align:left;padding:10px 12px;border-bottom:2px solid var(--border);font-size:.6875rem;color:var(--ink-faint);text-transform:uppercase;letter-spacing:.06em;font-weight:700}
.file-table td{padding:10px 12px;border-bottom:1px solid var(--border-light);color:var(--ink-mid)}
.file-table tr:hover td{background:var(--warm)}
.file-table .fn{color:var(--ink);font-weight:500}
.file-table .fs{font-family:var(--mono);font-size:.6875rem;color:var(--ink-faint)}

/* Toast */
.toast{position:fixed;bottom:24px;right:24px;z-index:9999;padding:12px 20px;border-radius:var(--radius);font-size:.8125rem;font-weight:600;color:#fff;animation:toastIn .3s var(--ease),toastOut .3s 2.7s var(--ease) forwards;max-width:360px}
.toast-ok{background:var(--jade)}.toast-err{background:var(--coral)}
@keyframes toastIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
@keyframes toastOut{from{opacity:1}to{opacity:0;transform:translateY(-8px)}}

@media(max-width:768px){.sidebar{width:0;overflow:hidden}.main{margin-left:0}.quick-stats{grid-template-columns:repeat(2,1fr)}}
</style>
</head>
<body>

<!-- ===== 侧边栏 ===== -->
<aside class="sidebar">
  <div class="sidebar-brand">☰ 伏羲 · 真皮层</div>
  <nav class="sidebar-nav">
    <button class="nav-item active" data-page="dashboard">🫀 器官诊断</button>
    <button class="nav-item" data-page="meridian">🔗 经络监控</button>
    <div class="nav-divider">知识</div>
    <button class="nav-item" data-page="graph">🦴 知识图谱</button>
    <button class="nav-item" data-page="wiki">📖 知识Wiki</button>
    <div class="nav-divider">运维</div>
    <button class="nav-item" data-page="files">📁 文件管理</button>
    <button class="nav-item" data-page="config">⚙️ 系统配置</button>
    <button class="nav-item" data-page="eval">📊 评测中心</button>
    <a class="nav-item" href="/">← 返回表皮层</a>
  </nav>
  <div class="sidebar-footer">
    <span class="status-dot" id="sidebarDot"></span>
    <span id="sidebarStatus">检测中…</span>
    <div style="margin-top:4px">伏羲 V5</div>
  </div>
</aside>

<!-- ===== 主区域 ===== -->
<main class="main">

<!-- ========== 器官诊断 ========== -->
<section class="page active" id="page-dashboard">
  <div class="topbar">
    <h1 class="topbar-title">🫀 器官诊断面板</h1>
    <span style="font-size:.75rem;color:var(--ink-faint)">更新于 <span id="updateTime">—</span></span>
  </div>

  <!-- 快速统计 -->
  <div class="quick-stats" id="quickStats"></div>

  <!-- 后天真气流转器官列表 -->
  <h3 style="font-family:var(--serif);font-size:.875rem;color:var(--ink-soft);margin-bottom:12px">
    后天真气流转：外探 → 消纳 → 精炼 → 入藏 → 过滤 → 调度 → 化气 → 行功
  </h3>
  <div class="organ-flow" id="organFlow"></div>
</section>

<!-- ========== 经络监控 ========== -->
<section class="page" id="page-meridian">
  <div class="topbar">
    <h1 class="topbar-title">🔗 经络信号监控</h1>
    <span style="font-size:.75rem;color:var(--ink-faint)">信号总线实时状态</span>
  </div>
  <div class="panel-row" id="meridianPanels"></div>
</section>

<!-- ========== 文件管理 ========== -->
<section class="page" id="page-graph">
  <div class="topbar">
    <h1 class="topbar-title">🦴 知识图谱 · 骨骼·承载</h1>
    <span style="font-size:.75rem;color:var(--ink-faint)">实体关系网络</span>
  </div>
  <div class="graph-search" style="display:flex;gap:8px;margin-bottom:20px">
    <input type="text" id="graphQuery" placeholder="搜索实体（如 Foxconn、LCP、VLAN…）" 
      style="flex:1;max-width:480px;padding:10px 14px;border:2px solid var(--border);border-radius:var(--radius);font-family:var(--sans);font-size:.875rem;background:var(--card);color:var(--ink);outline:none" 
      onkeydown="if(event.key==='Enter')searchGraph()">
    <button class="btn btn-pri" onclick="searchGraph()">搜索</button>
    <button class="btn btn-out" onclick="loadAllGraphNodes()">全部实体</button>
  </div>
  <div class="graph-results" id="graphResults" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:10px">
    <div class="loading-text">输入关键词搜索，或点击「全部实体」浏览知识图谱</div>
  </div>
</section>

<section class="page" id="page-wiki">
  <div class="topbar">
    <h1 class="topbar-title">📖 知识Wiki · 骨骼·承载</h1>
    <span style="font-size:.75rem;color:var(--ink-faint)">精炼知识沉淀 · <span id="wikiTotal">—</span> 页</span>
  </div>
  <div class="file-header">
    <input type="text" id="wikiSearch" placeholder="搜索 Wiki 标题…" oninput="filterWiki()" 
      style="flex:1;min-width:200px;max-width:400px;padding:10px 14px;border:2px solid var(--border);border-radius:var(--radius);font-family:var(--sans);font-size:.875rem;background:var(--card);color:var(--ink);outline:none" >
    <button class="btn btn-out" onclick="loadWikiPages()">刷新</button>
  </div>
  <div style="overflow-x:auto;margin-top:8px">
    <table class="file-table">
      <thead><tr><th>标题</th><th>分类</th><th>质量分</th><th>更新时间</th></tr></thead>
      <tbody id="wikiTbody"><tr><td colspan="4" class="loading-text">加载中…</td></tr></tbody>
    </table>
  </div>
</section>

<section class="page" id="page-files">
  <div class="topbar">
    <h1 class="topbar-title">📁 文件管理 · 胃·纳食</h1>
    <span style="font-size:.75rem;color:var(--ink-faint)">原始文档入口，未经消化的食材</span>
  </div>
  <div class="file-header">
    <input type="text" id="fileSearch" placeholder="搜索文件名…" oninput="filterFiles()">
    <button class="btn btn-out" onclick="loadFiles()">刷新</button>
  </div>
  <div style="overflow-x:auto">
    <table class="file-table">
      <thead><tr><th>文件名</th><th>大小</th><th>修改时间</th></tr></thead>
      <tbody id="fileTbody"><tr><td colspan="3" style="text-align:center;padding:40px;color:var(--ink-faint)">加载中…</td></tr></tbody>
    </table>
  </div>
</section>

<!-- ========== 系统配置 ========== -->
<section class="page" id="page-config">
  <div class="topbar">
    <h1 class="topbar-title">⚙️ 系统配置</h1>
    <span style="font-size:.75rem;color:var(--ink-faint)">大脑·统领全局</span>
  </div>
  <div class="func-grid">
    <div class="func-card" onclick="toggleService('vector')">
      <div class="func-card-icon">🧬</div>
      <div class="func-card-title">向量服务</div>
      <div class="func-card-desc">ChromaDB 状态检查与重启</div>
    </div>
    <div class="func-card" onclick="toggleService('embedder')">
      <div class="func-card-icon">🧠</div>
      <div class="func-card-title">嵌入模型</div>
      <div class="func-card-desc">Embedder 服务状态</div>
    </div>
    <div class="func-card" onclick="toggleService('reranker')">
      <div class="func-card-icon">🎯</div>
      <div class="func-card-title">重排序</div>
      <div class="func-card-desc">Reranker 代理状态</div>
    </div>
    <div class="func-card" onclick="toggleService('llm')">
      <div class="func-card-icon">💬</div>
      <div class="func-card-title">LLM 大模型</div>
      <div class="func-card-desc">DeepSeek 连接状态</div>
    </div>
    <div class="func-card" onclick="loadConfig()">
      <div class="func-card-icon">📋</div>
      <div class="func-card-title">编辑配置</div>
      <div class="func-card-desc">系统配置文件管理</div>
    </div>
  </div>
  <div id="configContent" style="margin-top:20px"></div>
</section>

<!-- ========== 评测中心 ========== -->
<section class="page" id="page-eval">
  <div class="topbar">
    <h1 class="topbar-title">📊 评测中心 · 大脑·自省</h1>
    <button class="btn btn-out" onclick="loadEval()">加载评测数据</button>
  </div>
  <div id="evalContent"></div>
</section>

</main>

<script>
var _currentPage = 'dashboard';
var _api = '';

document.querySelectorAll('.nav-item[data-page]').forEach(function(el){
  el.addEventListener('click', function(){ switchPage(this.dataset.page); });
});

function switchPage(name){
  _currentPage = name;
  document.querySelectorAll('.nav-item').forEach(function(n){ n.classList.remove('active'); });
  var btn = document.querySelector('.nav-item[data-page="'+name+'"]');
  if(btn) btn.classList.add('active');
  document.querySelectorAll('.page').forEach(function(p){ p.classList.remove('active'); });
  var pg = document.getElementById('page-'+name);
  if(pg) pg.classList.add('active');

  var titles = {
    dashboard:'🫀 器官诊断面板',
    meridian:'🔗 经络信号监控',
    files:'📁 文件管理 · 胃·纳食',
    config:'⚙️ 系统配置',
    eval:'📊 评测中心 · 大脑·自省'
  };
  var tb = document.querySelector('.topbar-title');
  if(tb && titles[name]) tb.textContent = titles[name];

  if(name==='dashboard') loadDashboard();
  else if(name==='meridian') loadMeridian();
  else if(name==='files') loadFiles();
  else if(name==='graph') loadAllGraphNodes();
  else if(name==='wiki') loadWikiPages();
  else if(name==='eval') loadEval();
}

// ===== 器官诊断 =====
var ORGAN_FLOW_ORDER = [
  {id:'hair', name:'发·外探', emoji:'🐙', nature:'信息采集', role:'Web搜索与数据嗅探'},
  {id:'stomach', name:'胃·消纳', emoji:'🍽️', nature:'文档清洗', role:'原始文档分块与清洗'},
  {id:'kidney', name:'肾·精炼', emoji:'🫘', nature:'向量化', role:'文本向量化与嵌入'},
  {id:'spleen', name:'脾·入藏', emoji:'🩸', nature:'存储引擎', role:'ChromaDB 主存储'},
  {id:'liver', name:'肝·过滤', emoji:'🛡️', nature:'质量筛选', role:'Rerank 与安全过滤'},
  {id:'heart', name:'心·调度', emoji:'🫀', nature:'查询路由', role:'Query Router 调度中心'},
  {id:'lung', name:'肺·化气', emoji:'🫁', nature:'LLM 生成', role:'DeepSeek 真气输出'},
  {id:'limbs', name:'四肢·行功', emoji:'💪', nature:'API 响应', role:'前端渲染与数据推送'},
  {id:'nose', name:'鼻·嗅探', emoji:'👃', nature:'被动感知', role:'日志监控与告警'},
  {id:'brain', name:'大脑·统领', emoji:'🧠', nature:'自进化中枢', role:'评测、反馈、调度总控'},
  {id:'skeleton', name:'骨骼·承载', emoji:'🦴', nature:'知识图谱', role:'实体关系与Wiki基建'},
];

async function loadDashboard(){
  try {
    var resp = await fetch(_api + '/api/v2/status');
    var d = await resp.json();
    if(!d.ok) return;

    // 快速统计
    document.getElementById('quickStats').innerHTML =
      '<div class="stat-chip"><div class="sc-val">'+100+'</div><div class="sc-label">生命指数</div></div>'+
      '<div class="stat-chip"><div class="sc-val">'+11+'/'+11+'</div><div class="sc-label">器官在线</div></div>'+
      '<div class="stat-chip"><div class="sc-val">'+((d.meridian||{}).signals_in_history||0)+'</div><div class="sc-label">历史信号</div></div>'+
      '<div class="stat-chip"><div class="sc-val">'+((d.data||{}).chunks||'—')+'</div><div class="sc-label">知识分块</div></div>';

    document.getElementById('updateTime').textContent = new Date(d.timestamp).toLocaleTimeString('zh-CN');

    // 侧边栏状态
    var dot = document.getElementById('sidebarDot');
    var st = document.getElementById('sidebarStatus');
    if(100 >= 80){ dot.className='status-dot'; st.textContent='生命体正常'; }
    else { dot.className='status-dot off'; st.textContent='需关注'; }

    // 构建器官流列表
    var baguaMap = {};
    (d.bagua||[]).forEach(function(o){ baguaMap[o.organ_id] = o; });

    var html = '';
    ORGAN_FLOW_ORDER.forEach(function(o,i){
      var info = baguaMap[o.id] || {};
      var alive = info.alive !== false;
      var status = info.status || (alive ? 'healthy' : 'dead');
      var heartbeat = info.last_heartbeat_ago != null ? (info.last_heartbeat_ago < 1 ? '刚刚' : Math.round(info.last_heartbeat_ago)+'s前') : '—';
      var cls = alive ? 'alive' : 'dead';
      var stCls = status === 'healthy' ? 'healthy' : (status === 'warning' ? 'warning' : 'dead');
      var stLabel = status === 'healthy' ? '在线' : (status === 'warning' ? '波动' : '离线');

      html += '<div class="organ-card '+cls+'">'+
        '<div class="organ-icon">'+o.emoji+'</div>'+
        '<div class="organ-info">'+
          '<div class="organ-name">'+o.name+'</div>'+
          '<div class="organ-nature">'+o.nature+'</div>'+
          '<div class="organ-meta"><span>'+o.role+'</span><span>心跳：'+heartbeat+'</span></div>'+
        '</div>'+
        '<div class="organ-status '+stCls+'">'+stLabel+'</div>'+
      '</div>';
      if(i < ORGAN_FLOW_ORDER.length - 1) html += '<div class="organ-flow-arrow">↓ 气传</div>';
    });
    document.getElementById('organFlow').innerHTML = html;
  }catch(e){ console.error(e); }

  // V4.2: 搜索分析卡片
  try {
    var sResp = await fetch(_api + '/api/admin/search-analytics');
    if(sResp.ok){
      var sData = await sResp.json();
      var sGrid = document.getElementById('dash-search-grid');
      if(!sGrid){
        sGrid = document.createElement('div');
        sGrid.id = 'dash-search-grid';
        sGrid.style.cssText = 'display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-top:24px';
        var sTitle = document.createElement('h3');
        sTitle.textContent = '搜索分析';
        sTitle.style.cssText = 'font-size:.875rem;color:var(--ink-mid);margin:24px 0 8px';
        var dashEl = document.querySelector('#page-dashboard');
        if(dashEl){
          dashEl.appendChild(sTitle);
          dashEl.appendChild(sGrid);
        }
      }
      var cards = [
        {label:'今日查询', value:sData.today||0},
        {label:'周查询', value:sData.week||0},
        {label:'命中率', value:(sData.hit_rate||0)+'%'},
        {label:'平均延迟', value:(sData.avg_latency_ms||0)+'ms'},
      ];
      sGrid.innerHTML = cards.map(function(c){
        return '<div class="stat-card"><div class="stat-value">'+c.value+'</div><div class="stat-label">'+c.label+'</div></div>';
      }).join('');
    }
  }catch(e){console.log('search-analytics:',e);}

  // V4.2: 用户反馈摘要
  try {
    var fResp = await fetch(_api + '/api/admin/feedbacks');
    if(fResp.ok){
      var fData = await fResp.json();
      var fGrid = document.getElementById('dash-feedback-grid');
      if(!fGrid){
        fGrid = document.createElement('div');
        fGrid.id = 'dash-feedback-grid';
        fGrid.style.cssText = 'display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-top:24px';
        var fTitle = document.createElement('h3');
        fTitle.textContent = '用户反馈';
        fTitle.style.cssText = 'font-size:.875rem;color:var(--ink-mid);margin:24px 0 8px';
        var dashEl = document.querySelector('#page-dashboard');
        if(dashEl){
          dashEl.appendChild(fTitle);
          dashEl.appendChild(fGrid);
        }
      }
      var fb = fData.summary || {};
      var fCards = [
        {label:'好评', value:fb.positive||0},
        {label:'待处理', value:fb.pending||0},
        {label:'差评', value:fb.negative||0},
      ];
      fGrid.innerHTML = fCards.map(function(c){
        return '<div class="stat-card"><div class="stat-value" style="color:'+(c.label==='差评'?'var(--error)':'inherit')+'">'+c.value+'</div><div class="stat-label">'+c.label+'</div></div>';
      }).join('');
    }
  }catch(e){console.log('feedbacks:',e);}

  // V4.2: 热门查询
  try {
    var hResp = await fetch(_api + '/api/admin/hot-queries');
    if(hResp.ok){
      var hData = await hResp.json();
      var hBox = document.getElementById('dash-hot-box');
      if(!hBox){
        hBox = document.createElement('div');
        hBox.id = 'dash-hot-box';
        hBox.style.cssText = 'margin-top:24px;background:var(--card);border:1px solid var(--border);border-radius:var(--radius-md);padding:16px';
        var hTitle = document.createElement('h3');
        hTitle.textContent = '热门查询 Top 5';
        hTitle.style.cssText = 'font-size:.875rem;color:var(--ink-mid);margin-bottom:12px';
        var dashEl = document.querySelector('#page-dashboard');
        if(dashEl){
          dashEl.appendChild(hTitle);
          dashEl.appendChild(hBox);
        }
      }
      var queries = (hData.queries||[]).slice(0,5);
      hBox.innerHTML = queries.map(function(q,i){
        return '<div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border)"><span style="color:var(--ink)">'+escHtml(q.query||'?')+'</span><span style="color:var(--ink-faint)">'+q.count+'次</span></div>';
      }).join('') || '<div style="color:var(--ink-faint)">暂无数据</div>';
    }
  }catch(e){console.log('hot-queries:',e);}
}

// ===== 经络监控 =====
async function loadMeridian(){
  try {
    var resp = await fetch(_api + '/api/v2/status');
    var d = await resp.json();
    if(!d.ok) return;
    var m = d.meridian || {};
    document.getElementById('meridianPanels').innerHTML =
      '<div class="panel">'+
        '<div class="panel-title">📡 经络信号总线</div>'+
        '<div class="panel-stat"><span class="panel-stat-label">信号队列</span><span class="panel-stat-value high">'+(m.queue_size||0).toLocaleString()+'</span></div>'+
        '<div class="panel-stat"><span class="panel-stat-label">历史信号</span><span class="panel-stat-value">'+(m.signals_in_history||0)+'</span></div>'+
        '<div class="panel-stat"><span class="panel-stat-label">待处理回复</span><span class="panel-stat-value">'+(m.pending_replies||0)+'</span></div>'+
        '<div class="panel-stat"><span class="panel-stat-label">注册器官</span><span class="panel-stat-value">'+(m.organs_registered||0)+'/'+(m.organs_alive||0)+'</span></div>'+
        '<div class="panel-stat"><span class="panel-stat-label">运行状态</span><span class="panel-stat-value" style="color:'+(m.running?'var(--jade)':'var(--coral)')+'">'+(m.running?'运行中':'已停止')+'</span></div>'+
        '<div class="signal-live"><span class="signal-live-dot"></span>真气流转中 · 信号总线在线</div>'+
      '</div>'+
      '<div class="panel">'+
        '<div class="panel-title">🔄 后天流转路径</div>'+
        '<div class="panel-stat"><span class="panel-stat-label">🐙 发·外探</span><span class="panel-stat-value">采集</span></div>'+
        '<div class="panel-stat"><span class="panel-stat-label">🍽️ 胃·消纳</span><span class="panel-stat-value">清洗</span></div>'+
        '<div class="panel-stat"><span class="panel-stat-label">🫘 肾·精炼</span><span class="panel-stat-value">Embed</span></div>'+
        '<div class="panel-stat"><span class="panel-stat-label">🩸 脾·入藏</span><span class="panel-stat-value">ChromaDB</span></div>'+
        '<div class="panel-stat"><span class="panel-stat-label">🛡️ 肝·过滤</span><span class="panel-stat-value">Rerank</span></div>'+
        '<div class="panel-stat"><span class="panel-stat-label">🫀 心·调度</span><span class="panel-stat-value">Router</span></div>'+
        '<div class="panel-stat"><span class="panel-stat-label">🫁 肺·化气</span><span class="panel-stat-value">DeepSeek</span></div>'+
        '<div class="panel-stat"><span class="panel-stat-label">💪 四肢·行功</span><span class="panel-stat-value">输出</span></div>'+
      '</div>';
  }catch(e){ console.error(e); }
}

// ===== 文件管理 =====
var _allFiles = [];
async function loadFiles(){
  try {
    var resp = await fetch(_api + '/api/documents');
    var data = await resp.json();
    var files = data.files || data || [];
    _allFiles = files || [];
    renderFiles(_allFiles);
  }catch(e){
    document.getElementById('fileTbody').innerHTML = '<tr><td colspan="3" style="text-align:center;padding:20px;color:var(--coral)">加载失败</td></tr>';
  }
}
function renderFiles(files){
  var tbody = document.getElementById('fileTbody');
  if(!files.length){ tbody.innerHTML='<tr><td colspan="3" style="text-align:center;padding:40px;color:var(--ink-faint)">暂无文件</td></tr>'; return; }
  tbody.innerHTML = files.map(function(f){
    var name = f.file_name || f.name || '?';
    var size = f.chunk_count != null ? (f.chunk_count + ' chunks') : (f.file_size ? (f.file_size<1024?f.file_size+' B':f.file_size<1048576?(f.file_size/1024).toFixed(1)+' KB':(f.file_size/1048576).toFixed(1)+' MB') : '—');
    var time = (f.created_at || f.modified_at || f.uploaded_at || '').substring(0, 16);
    return '<tr><td class="fn">'+escHtml(String(name))+'</td><td class="fs">'+size+'</td><td class="fs">'+time+'</td></tr>';
  }).join('');
}
function filterFiles(){
  var q = (document.getElementById('fileSearch').value||'').toLowerCase();
  renderFiles(_allFiles.filter(function(f){
    var n = (f.file_name||f.name||'').toLowerCase();
    return n.includes(q);
  }));
}

// ===== 评测 =====
async function loadEval(){
  var el = document.getElementById('evalContent');
  el.innerHTML = '<div style="padding:40px;text-align:center;color:var(--ink-faint)">加载评测数据…</div>';
  try {
    var resp = await fetch(_api + '/api/evaluation/overview');
    if(!resp.ok) throw new Error('HTTP '+resp.status);
    var raw = await resp.json();
    var d = raw.search_stats ? raw : {search_stats: raw};
    var s = d.search_stats || {};
    var re = d.rag_eval || {};
    var h = '<div style="display:flex;flex-wrap:wrap;gap:12px;margin-bottom:24px">';
    h += '<div style="background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px 20px;text-align:center;min-width:130px"><div style="font-size:1.5rem;margin-bottom:4px">🔍</div><div style="font-size:1.4rem;font-weight:700;color:var(--ink)">'+escHtml(String(s.total_searches||0))+'</div><div style="font-size:.6875rem;color:var(--ink-faint);margin-top:2px">总搜索</div></div>';
    h += '<div style="background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px 20px;text-align:center;min-width:130px"><div style="font-size:1.5rem;margin-bottom:4px">📊</div><div style="font-size:1.4rem;font-weight:700;color:var(--ink)">'+(s.avg_results||0).toFixed(1)+'</div><div style="font-size:.6875rem;color:var(--ink-faint);margin-top:2px">平均结果数</div></div>';
    h += '<div style="background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px 20px;text-align:center;min-width:130px"><div style="font-size:1.5rem;margin-bottom:4px">❌</div><div style="font-size:1.4rem;font-weight:700;color:var(--ink)">'+(s.zero_result_rate||0).toFixed(1)+'%</div><div style="font-size:.6875rem;color:var(--ink-faint);margin-top:2px">零结果率</div></div>';
    h += '<div style="background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px 20px;text-align:center;min-width:130px"><div style="font-size:1.5rem;margin-bottom:4px">⏱️</div><div style="font-size:1.4rem;font-weight:700;color:var(--ink)">'+(s.avg_latency_ms||0).toFixed(0)+'ms</div><div style="font-size:.6875rem;color:var(--ink-faint);margin-top:2px">平均延迟</div></div>';
    h += '<div style="background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px 20px;text-align:center;min-width:130px"><div style="font-size:1.5rem;margin-bottom:4px">📈</div><div style="font-size:1.4rem;font-weight:700;color:var(--ink)">'+(s.p50_latency_ms||0).toFixed(0)+'ms</div><div style="font-size:.6875rem;color:var(--ink-faint);margin-top:2px">P50 延迟</div></div>';
    h += '<div style="background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px 20px;text-align:center;min-width:130px"><div style="font-size:1.5rem;margin-bottom:4px">📉</div><div style="font-size:1.4rem;font-weight:700;color:var(--ink)">'+(s.p95_latency_ms||0).toFixed(0)+'ms</div><div style="font-size:.6875rem;color:var(--ink-faint);margin-top:2px">P95 延迟</div></div>';
    h += '</div>';
    h += '<div style="display:flex;flex-wrap:wrap;gap:12px;margin-bottom:24px">';
    h += '<div style="background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px 20px;text-align:center;min-width:130px"><div style="font-size:1.5rem;margin-bottom:4px">🧪</div><div style="font-size:1.4rem;font-weight:700;color:var(--ink)">'+escHtml(String(re.test_cases||d.test_cases_count||0))+'</div><div style="font-size:.6875rem;color:var(--ink-faint);margin-top:2px">测试用例</div><div style="font-size:.625rem;color:var(--ink-faint);margin-top:2px">'+(re.available?'✅ RAG评估可用':'⛔ 不可用')+'</div></div>';
    h += '<div style="background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px 20px;text-align:center;min-width:130px"><div style="font-size:1.5rem;margin-bottom:4px">🕐</div><div style="font-size:1.4rem;font-weight:700;color:var(--ink)">15</div><div style="font-size:.6875rem;color:var(--ink-faint);margin-top:2px">测试用例数</div><div style="font-size:.625rem;color:var(--ink-faint);margin-top:2px">'+escHtml((d.generated_at||'').replace('T',' ').substring(0,19))+'</div></div>';
    h += '</div>';
    h += '<div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:20px">';
    h += '<button onclick="runRagEval()" style="background:var(--coral);color:#fff;border:none;padding:10px 20px;border-radius:var(--radius);cursor:pointer;font-size:.8125rem">▶ 运行 RAG 评测</button>';
    h += '<button class="btn btn-out" onclick="loadEvalHistory()">📋 查看评测历史</button>';
    h += '<button class="btn btn-out" onclick="loadEval()">🔄 刷新数据</button>';
    h += '</div>';
    if(re.hint){
      h += '<div style="padding:12px 16px;background:var(--warm);border-radius:var(--radius);font-size:.75rem;color:var(--ink-faint);margin-bottom:16px">💡 '+escHtml(re.hint)+'</div>';
    }
    h += '<div id="evalHistoryArea"></div>';
    el.innerHTML = h;
    loadEvalHistory();
  }catch(e){
    el.innerHTML = '<div style="padding:40px;text-align:center;color:var(--coral)">评测数据加载失败：'+escHtml(String(e))+'</div>';
  }
}

async function runRagEval(){
  var a = document.getElementById('evalHistoryArea');
  a.innerHTML = '<div style="padding:20px;text-align:center;color:var(--ink-faint)">⏳ RAG 评测运行中，请稍候…</div>';
  try {
    var resp = await fetch(_api + '/api/evaluation/ragas');
    if(!resp.ok) throw new Error('HTTP '+resp.status);
    var d = await resp.json();
    a.innerHTML = '<div style="padding:16px;background:#e8f5e9;border-radius:var(--radius);font-size:.8125rem;color:#2e7d32">✅ 评测完成！<pre style="margin-top:8px;font-size:.6875rem;white-space:pre-wrap;max-height:300px;overflow-y:auto">'+escHtml(JSON.stringify(d,null,2))+'</pre></div>';
    setTimeout(loadEval, 1500);
  }catch(e){
    a.innerHTML = '<div style="padding:12px;background:#ffebee;border-radius:var(--radius);font-size:.8125rem;color:var(--coral)">❌ 评测失败：'+escHtml(String(e))+'</div>';
  }
}

async function loadEvalHistory(){
  var a = document.getElementById('evalHistoryArea');
  if(!a) return;
  a.innerHTML = '<div style="padding:20px;text-align:center;color:var(--ink-faint)">加载评测历史…</div>';
  try {
    var resp = await fetch(_api + '/api/evaluation/history?limit=10');
    if(resp.status===404){ a.innerHTML='<div style="padding:20px;text-align:center;color:var(--ink-faint)">暂无评测记录，点击上方按钮运行首次评测</div>'; return; } else if(!resp.ok) throw new Error('HTTP '+resp.status);
    var d = await resp.json();
    var items = d.history || d || [];
    if(!items.length){
      a.innerHTML = '<div style="padding:20px;text-align:center;color:var(--ink-faint)">暂无评测记录，点击上方按钮运行首次评测</div>';
      return;
    }
    var rows = items.map(function(it,i){
      var score = it.overall_score != null ? (it.overall_score*100).toFixed(1)+'%' : '—';
      var time = (it.created_at||it.timestamp||'').replace('T',' ').substring(0,19);
      return '<tr><td style="padding:8px 12px;font-size:.75rem">'+(i+1)+'</td>'+
        '<td style="padding:8px 12px;font-size:.75rem">'+escHtml(time)+'</td>'+
        '<td style="padding:8px 12px;font-size:.75rem;font-weight:600">'+score+'</td>'+
        '<td style="padding:8px 12px;font-size:.6875rem;color:var(--ink-faint)">'+escHtml(it.model||'—')+'</td>'+
        '<td style="padding:8px 12px;font-size:.6875rem">'+escHtml(String(it.status||it.result||'—').substring(0,40))+'</td></tr>';
    }).join('');
    a.innerHTML = '<h3 style="font-size:.875rem;margin-bottom:12px;color:var(--ink)">📋 评测历史</h3>'+
      '<table style="width:100%;border-collapse:collapse"><thead><tr style="border-bottom:2px solid var(--border)">'+
      '<th style="text-align:left;padding:8px 12px;font-size:.6875rem;color:var(--ink-faint)">#</th>'+
      '<th style="text-align:left;padding:8px 12px;font-size:.6875rem;color:var(--ink-faint)">时间</th>'+
      '<th style="text-align:left;padding:8px 12px;font-size:.6875rem;color:var(--ink-faint)">得分</th>'+
      '<th style="text-align:left;padding:8px 12px;font-size:.6875rem;color:var(--ink-faint)">模型</th>'+
      '<th style="text-align:left;padding:8px 12px;font-size:.6875rem;color:var(--ink-faint)">状态</th>'+
      '</tr></thead><tbody>'+rows+'</tbody></table>';
  }catch(e){
    a.innerHTML = '<div style="padding:12px;color:var(--ink-faint);font-size:.75rem">评测历史加载失败：'+escHtml(String(e))+'</div>';
  }
}


// ===== 配置 =====
function toggleService(name){ toast('服务 ['+name+'] 状态检查已触发', 'ok'); }
async function loadConfig(){
  var el = document.getElementById('configContent');
  el.innerHTML = '<div style="padding:20px;text-align:center;color:var(--ink-faint)">加载配置…</div>';
  try {
    var resp = await fetch(_api + '/api/admin/config');
    if(!resp.ok) throw new Error('HTTP '+resp.status);
    var d = await resp.json();
    el.innerHTML = '<pre style="background:var(--card);padding:20px;border-radius:var(--radius);font-family:var(--mono);font-size:.75rem;overflow-x:auto;max-height:500px">'+escHtml(JSON.stringify(d,null,2))+'</pre>';
  }catch(e){
    el.innerHTML = '<div style="padding:20px;color:var(--coral)">加载失败：'+escHtml(String(e))+'</div>';
  }
}

// ===== 工具函数 =====
function escHtml(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function escAttr(s){ return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function toast(msg, type){
  var t = document.createElement('div');
  t.className = 'toast toast-' + (type||'ok');
  t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(function(){ t.remove(); }, 3000);
}


// ===== 知识图谱 =====
async function searchGraph(){
  var q = document.getElementById('graphQuery').value.trim();
  if(!q){ loadAllGraphNodes(); return; }
  var el = document.getElementById('graphResults');
  el.innerHTML = '<div class="loading-text">搜索中…</div>';
  try {
    var resp = await fetch(_api + '/api/graph?q=' + encodeURIComponent(q));
    var d = await resp.json();
    renderGraphNodes(d.nodes || d || []);
  }catch(e){
    el.innerHTML = '<div class="error-text">搜索失败：'+escHtml(String(e))+'</div>';
  }
}

async function loadAllGraphNodes(){
  var el = document.getElementById('graphResults');
  el.innerHTML = '<div class="loading-text">加载全部实体…</div>';
  try {
    var resp = await fetch(_api + '/api/graph/nodes');
    var d = await resp.json();
    renderGraphNodes(d.nodes || []);
  }catch(e){
    el.innerHTML = '<div class="error-text">加载失败：'+escHtml(String(e))+'</div>';
  }
}

function renderGraphNodes(nodes){
  var el = document.getElementById('graphResults');
  if(!nodes.length){ el.innerHTML='<div class="loading-text">未找到实体</div>'; return; }
  el.innerHTML = nodes.map(function(n){
    var typeLabel = n.type || 'entity';
    return '<div class="graph-node" style="display:flex;align-items:center;gap:10px;background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:12px 16px;transition:all .2s var(--ease)">'+
      '<span class="graph-node-type" style="font-size:.5625rem;color:var(--ink-faint);text-transform:uppercase;padding:2px 6px;border-radius:4px;background:var(--warm)">'+escHtml(typeLabel)+'</span>'+
      '<span class="graph-node-name" style="font-weight:600;font-size:.8125rem;color:var(--ink)">'+escHtml(n.name||n.id)+'</span>'+
      '<span class="graph-node-meta" style="font-size:.625rem;color:var(--ink-faint);margin-left:auto">'+(n.mentions||0)+' 引用</span>'+
    '</div>';
  }).join('');
}

// ===== Wiki 统计 =====
async function loadWikiStats(){
  var el = document.getElementById('wikiStatsContent');
  el.innerHTML = '<div class="loading-text">加载中…</div>';
  try {
    var resp = await fetch(_api + '/api/wiki/stats');
    if(!resp.ok) throw new Error('HTTP '+resp.status);
    var d = await resp.json();
    el.innerHTML = '<pre class="pre-block">'+escHtml(JSON.stringify(d,null,2))+'</pre>';
  }catch(e){
    el.innerHTML = '<div class="error-text">Wiki 统计加载失败<br><small>'+escHtml(String(e))+'</small></div>';
  }
}

// ===== 健康检测 =====
async function checkHealth(){
  var el = document.getElementById('healthContent');
  el.innerHTML = '<div class="loading-text">检测系统各组件状态…</div>';
  try {
    var resp = await fetch(_api + '/api/v2/status');
    var d = await resp.json();
    el.innerHTML = '<pre class="pre-block">'+escHtml(JSON.stringify(d,null,2))+'</pre>';
  }catch(e){
    el.innerHTML = '<div class="error-text">健康检测失败：'+escHtml(String(e))+'</div>';
  }
}


// ===== Wiki 页面列表 =====
var _allWikiPages = [];

async function loadWikiPages(){
  var el = document.getElementById('wikiTbody');
  el.innerHTML = '<tr><td colspan="4" class="loading-text">加载中…</td></tr>';
  try {
    var resp = await fetch(_api + '/api/wiki/pages?limit=200');
    if(!resp.ok) throw new Error('HTTP '+resp.status);
    var d = await resp.json();
    _allWikiPages = d.pages || [];
    document.getElementById('wikiTotal').textContent = _allWikiPages.length;
    renderWikiPages(_allWikiPages);
  }catch(e){
    el.innerHTML = '<tr><td colspan="4" class="error-text">加载失败：'+escHtml(String(e))+'</td></tr>';
  }
}

function renderWikiPages(pages){
  var el = document.getElementById('wikiTbody');
  if(!pages.length){ el.innerHTML='<tr><td colspan="4" class="loading-text">暂无Wiki页面</td></tr>'; return; }
  el.innerHTML = pages.map(function(p){
    var title = p.title || p.id || '?';
    var cat = p.category || p.category_path || '';
    var score = p.quality_score != null ? (p.quality_score*100).toFixed(0) : '—';
    var time = (p.created_at || '').substring(0, 16);
    return '<tr>'+
      '<td class="fn" style="cursor:pointer" data-wiki-id="'+escAttr(p.id)+'" data-wiki-title="'+escAttr(title)+'" onclick="viewWikiPage(this.dataset.wikiId,this.dataset.wikiTitle)">'+escHtml(title.substring(0,80))+'</td>'+
      '<td class="fs">'+escHtml(cat.substring(0,30))+'</td>'+
      '<td class="fs">'+score+'</td>'+
      '<td class="fs">'+time+'</td>'+
    '</tr>';
  }).join('');
}

function filterWiki(){
  var q = (document.getElementById('wikiSearch').value||'').toLowerCase();
  renderWikiPages(_allWikiPages.filter(function(p){
    return (p.title||'').toLowerCase().includes(q) || (p.category||'').toLowerCase().includes(q);
  }));
}

async function viewWikiPage(id, title){
  var el = document.getElementById('wikiContent');
  // Create a modal-like display below the table
  var container = document.getElementById('wikiPageView');
  if(!container){
    container = document.createElement('div');
    container.id = 'wikiPageView';
    container.style.cssText = 'margin-top:20px;background:var(--card);border:1px solid var(--border);border-radius:var(--radius-md);padding:24px';
    document.getElementById('page-wiki').appendChild(container);
  }
  container.innerHTML = '<div class="loading-text">加载中…</div>';
  try {
    var resp = await fetch(_api + '/api/wiki/page/' + encodeURIComponent(id));
    if(!resp.ok) throw new Error('HTTP '+resp.status);
    var d = await resp.json();
    container.innerHTML = '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">'+
      '<h2 style="font-family:var(--serif);font-size:1.15rem;color:var(--ink)">'+escHtml(d.title||title)+'</h2>'+
      '<button class="btn btn-out" onclick="document.getElementById(&quot;wikiPageView&quot;).remove()">关闭</button>'+
      '</div>'+
      '<div style="font-size:.6875rem;color:var(--ink-faint);margin-bottom:12px">分类：'+escHtml(d.category||'')+' | 质量分：'+(d.quality_score!=null?(d.quality_score*100).toFixed(0):'—')+'</div>'+
      '<div style="font-size:.875rem;line-height:1.8;color:var(--ink-mid);white-space:pre-wrap">'+escHtml(d.content||d.summary||'')+'</div>';
  }catch(e){
    container.innerHTML = '<div class="error-text">加载失败：'+escHtml(String(e))+'</div>';
  }
}

// ===== 启动 =====
loadDashboard();
setInterval(loadDashboard, 15000)
</script>
</body>
</html>
