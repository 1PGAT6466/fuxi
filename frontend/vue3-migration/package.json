{
  "name": "fuxi-frontend-vue3",
  "version": "1.50.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .vue,.js,.ts --fix",
    "lint:check": "eslint src --ext .vue,.js,.ts",
    "format": "prettier --write \"src/**/*.{vue,js,ts,scss,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{vue,js,ts,scss,css,json}\"",
    "check": "npm run lint:check && npm run format:check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "prepare": "npx husky"
  },
  "lint-staged": {
    "*.{vue,js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{scss,css,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.0",
    "@intlify/unplugin-vue-i18n": "^4.0.0",
    "axios": "^1.7.0",
    "dompurify": "^3.1.0",
    "echarts": "^6.1.0",
    "element-plus": "^2.7.0",
    "lib0": "^0.2.117",
    "lodash-es": "^4.17.0",
    "marked": "^12.0.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0",
    "y-protocols": "^1.0.7",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/ui": "^4.1.9",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.11",
    "chai": "^5.3.3",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "sass": "^1.101.0",
    "typescript": "^6.0.3",
    "unplugin-element-plus": "^0.11.2",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^5.4.21",
    "vitest": "^4.1.10"
  }
}
