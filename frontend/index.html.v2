<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>伏羲 4.2 · 知识助手</title>
<style>
:root {
  --bg: #FFF5EB;
  --bg-chat: #FFFFFF;
  --bg-side: #FFE4CC;
  --orange: #FF6900;
  --orange-light: #FF8C3A;
  --orange-dim: rgba(255,105,0,0.08);
  --orange-border: rgba(255,105,0,0.12);
  --text: #2D1F10;
  --text-dim: #8C6E4A;
  --text-light: #B89B7A;
  --radius: 16px;
  --shadow: 0 2px 16px rgba(255,105,0,0.06);
}
* { box-sizing:border-box; margin:0; padding:0; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: "Microsoft YaHei","PingFang SC","Noto Sans SC",system-ui,sans-serif;
  height:100vh;
  overflow:hidden;
}
button { font-family:inherit; }
input { font-family:inherit; }

/* 布局 */
.layout { display:flex; height:100vh; }

/* 左侧导航 */
.sidebar {
  width: 260px;
  background: var(--bg-side);
  border-right: 1px solid var(--orange-border);
  display: flex;
  flex-direction: column;
  flex-shrink:0;
}
.sidebar-header {
  padding: 20px 20px 12px;
  font-size: 18px;
  font-weight: 700;
  color: var(--orange);
  letter-spacing: .04em;
}
.sidebar-header span { font-size:12px; color:var(--text-dim); font-weight:400; }
.nav-item {
  padding: 12px 20px;
  cursor: pointer;
  font-size: 13px;
  color: var(--text-dim);
  border-left: 3px solid transparent;
  transition: all .2s;
  display: flex;
  align-items: center;
  gap: 10px;
}
.nav-item:hover { background: var(--orange-dim); color: var(--text); }
.nav-item.active { background: var(--orange-dim); color: var(--orange); border-left-color: var(--orange); font-weight: 600; }

/* 对话历史 */
.chat-history {
  flex:1;
  overflow-y:auto;
  padding: 8px 0;
}
.history-item {
  padding: 10px 20px;
  cursor: pointer;
  font-size: 12px;
  color: var(--text-dim);
  transition: all .2s;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.history-item:hover { background: var(--orange-dim); color: var(--text); }
.history-item .time { font-size: 10px; color: var(--text-light); }

/* 主聊天区 */
.chat-area {
  flex:1;
  display:flex;
  flex-direction:column;
  background: var(--bg-chat);
}
.chat-header {
  padding: 16px 24px;
  border-bottom: 1px solid var(--orange-border);
  display:flex;
  align-items:center;
  gap:12px;
}
.chat-header h2 { font-size:16px; font-weight:600; }
.chat-header .badge { font-size:11px; background:var(--orange-dim); color:var(--orange); padding:2px 10px; border-radius:10px; }
.chat-header-right { margin-left:auto; display:flex; gap:8px; }
.chat-header-right button {
  padding: 6px 14px;
  border-radius: 16px;
  border: 1px solid var(--orange-border);
  background: var(--bg-chat);
  cursor: pointer;
  font-size: 12px;
  color: var(--text-dim);
  transition: all .2s;
}
.chat-header-right button:hover { background: var(--orange-dim); color: var(--orange); }
.chat-header-right button.active { background: var(--orange); color: #fff; border-color: var(--orange); }

/* 消息区 */
.messages {
  flex:1;
  overflow-y:auto;
  padding: 24px;
  display:flex;
  flex-direction:column;
  gap:16px;
}
.msg {
  max-width: 80%;
  padding: 14px 18px;
  border-radius: var(--radius);
  font-size: 14px;
  line-height: 1.7;
  word-wrap: break-word;
}
.msg.user {
  align-self: flex-end;
  background: var(--orange);
  color: #fff;
  border-bottom-right-radius: 4px;
}
.msg.assistant {
  align-self: flex-start;
  background: var(--bg);
  border: 1px solid var(--orange-border);
  border-bottom-left-radius: 4px;
}
.msg.loading { opacity: 0.6; }
.msg .meta { font-size: 11px; color: var(--text-dim); margin-bottom: 6px; }
.msg.system { align-self:center; font-size:12px; color:var(--text-dim); background:transparent; max-width:90%; text-align:center; }

/* Markdown 风格 */
.msg.assistant h1,.msg.assistant h2,.msg.assistant h3 { color: var(--orange); margin: 8px 0 4px; font-size:14px; }
.msg.assistant code { background: var(--orange-dim); padding: 1px 6px; border-radius: 4px; font-size: 12px; }
.msg.assistant pre { background: var(--bg); padding: 12px; border-radius: 8px; overflow-x:auto; font-size:12px; border:1px solid var(--orange-border); }
.msg.assistant ul,.msg.assistant ol { padding-left:18px; }
.msg.assistant blockquote { border-left: 3px solid var(--orange); padding-left:12px; margin:8px 0; color:var(--text-dim); }

/* 输入区 */
.input-area {
  padding: 16px 24px;
  border-top: 1px solid var(--orange-border);
  display:flex;
  gap:10px;
  align-items:flex-end;
}
.input-area textarea {
  flex:1;
  padding: 12px 16px;
  border-radius: 22px;
  border: 1px solid var(--orange-border);
  background: var(--bg);
  font-size: 14px;
  color: var(--text);
  outline: none;
  resize: none;
  max-height: 120px;
  line-height: 1.5;
  font-family: inherit;
}
.input-area textarea:focus { border-color: var(--orange); }
.send-btn {
  width: 44px; height: 44px;
  border-radius: 50%;
  background: var(--orange);
  border: none;
  color: #fff;
  font-size: 18px;
  cursor: pointer;
  flex-shrink:0;
  transition: all .2s;
  display:flex;
  align-items:center;
  justify-content:center;
}
.send-btn:hover { background: var(--orange-light); }
.send-btn:disabled { opacity:0.5; cursor:default; }

/* 快速提示 */
.quick-hints { display:flex; gap:6px; flex-wrap:wrap; padding:0 24px 8px; }
.quick-hint {
  padding: 4px 14px;
  border-radius: 14px;
  background: var(--orange-dim);
  border: 1px solid var(--orange-border);
  color: var(--orange);
  cursor: pointer;
  font-size: 11px;
  transition: all .2s;
}
.quick-hint:hover { background: var(--orange); color: #fff; }

/* 消息来源卡片 */
.source-card {
  font-size:11px;
  padding:8px 12px;
  border-radius: 10px;
  background: var(--orange-dim);
  margin-top:6px;
  cursor: pointer;
  color: var(--orange);
}
.source-card:hover { background: var(--orange); color:#fff; }

/* 面板切换 */
.panel { display:none; flex:1; flex-direction:column; overflow:hidden; }
.panel.active { display:flex; }
</style>
</head>
<body>

<div class="layout">
  <!-- 侧边栏 -->
  <aside class="sidebar">
    <div class="sidebar-header">☰ 伏羲 4.2 <span>企业知识助手</span></div>
    <nav>
      <div class="nav-item active" onclick="switchPanel('chat')">💬 对话</div>
      <div class="nav-item" onclick="switchPanel('tools')">🔧 常用工具</div>
      <div class="nav-item" onclick="switchPanel('faq')">❓ 常见问题</div>
      <div class="nav-item" onclick="switchPanel('upload')">📤 上传文件</div>
    </nav>
    <div style="padding:12px 20px;font-size:11px;color:var(--text-light);border-top:1px solid var(--orange-border);margin-top:8px">对话历史</div>
    <div class="chat-history" id="chat-history"></div>
    <div style="padding:16px 20px;border-top:1px solid var(--orange-border)">
      <a href="/admin" target="_blank" style="color:var(--orange);font-size:12px;text-decoration:none">⚙️ 管理面板 →</a>
    </div>
  </aside>

  <!-- 对话面板 -->
  <div class="panel active" id="panel-chat">
    <div class="chat-area">
      <div class="chat-header">
        <h2>💬 知识问答</h2>
        <span class="badge" id="status-badge">在线</span>
        <div class="chat-header-right">
          <button id="ext-btn" class="active" onclick="toggleExternal()" title="联网搜索">🌐 联网搜索</button>
          <button onclick="clearChat()" title="清空对话">🗑</button>
        </div>
      </div>
      <div class="quick-hints">
        <span class="quick-hint" onclick="quickAsk('PA66 拉伸强度是多少？')">PA66 拉伸强度</span>
        <span class="quick-hint" onclick="quickAsk('VLAN 怎么配置？')">VLAN 配置</span>
        <span class="quick-hint" onclick="quickAsk('导柱导套选型标准？')">导柱导套选型</span>
        <span class="quick-hint" onclick="quickAsk('PLC 怎么选型？')">PLC 选型</span>
        <span class="quick-hint" onclick="quickAsk('三坐标测量流程？')">三坐标测量</span>
      </div>
      <div class="messages" id="messages">
        <div class="msg system">👋 我是伏羲，宝利根企业知识助手。你可以问我材料参数、工艺标准、设备配置…</div>
      </div>
      <div class="input-area">
        <textarea id="chat-input" rows="1" placeholder="输入问题…" onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendMessage()}"></textarea>
        <button class="send-btn" onclick="sendMessage()">➤</button>
      </div>
    </div>
  </div>

  <!-- 常用工具面板 -->
  <div class="panel" id="panel-tools">
    <div style="padding:24px;overflow-y:auto;flex:1">
      <h2 style="color:var(--orange);margin-bottom:16px">🔧 常用工具</h2>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px" id="tools-grid"></div>
    </div>
  </div>

  <!-- 常见问题面板 -->
  <div class="panel" id="panel-faq">
    <div style="padding:24px;overflow-y:auto;flex:1">
      <h2 style="color:var(--orange);margin-bottom:16px">❓ 常见问题</h2>
      <div id="faq-list"></div>
    </div>
  </div>

  <!-- 上传面板 -->
  <div class="panel" id="panel-upload">
    <div style="padding:24px;overflow-y:auto;flex:1;text-align:center">
      <h2 style="color:var(--orange);margin-bottom:24px">📤 上传文件到知识库</h2>
      <div style="border:2px dashed var(--orange);border-radius:var(--radius);padding:48px;cursor:pointer;max-width:500px;margin:0 auto"
           onclick="document.getElementById('user-file-input').click()"
           id="user-upload-zone">
        <div style="font-size:48px;margin-bottom:8px">📁</div>
        <p style="color:var(--text-dim)">点击或拖拽文件上传</p>
        <p style="font-size:11px;color:var(--text-light)">支持 PDF / DOCX / XLSX / TXT / 图片</p>
      </div>
      <input type="file" id="user-file-input" multiple onchange="userUpload(this.files)" accept=".pdf,.docx,.doc,.xlsx,.xls,.txt,.md,.csv,.json,.xml,.html,.htm,.jpg,.jpeg,.png,.gif,.bmp,.svg" style="display:none">
      <div id="upload-status" style="margin-top:16px;color:var(--orange)"></div>
    </div>
  </div>
</div>

<script>
const API = '';
let enableExternal = true;
let chatHistory = [];
let currentPanel = 'chat';
const adminToken = 'polygon-admin-2024';

// ========== 面板切换 ==========
function switchPanel(name) {
  currentPanel = name;
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('panel-' + name).classList.add('active');
  event.target.classList.add('active');
  if (name === 'tools') loadTools();
  if (name === 'faq') loadFAQ();
}

// ========== 对话功能 ==========
function toggleExternal() {
  enableExternal = !enableExternal;
  const btn = document.getElementById('ext-btn');
  btn.textContent = enableExternal ? '🌐 联网搜索' : '🌐 仅本地';
  btn.classList.toggle('active', enableExternal);
}

async function sendMessage() {
  const input = document.getElementById('chat-input');
  const q = input.value.trim();
  if (!q) return;
  
  input.value = '';
  addMessage('user', q);
  addMessage('assistant', '思考中…', true);
  
  chatHistory.push({ role: 'user', content: q });
  saveChatHistory();
  
  try {
    const res = await fetch(API + '/api/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ query: q, history: chatHistory.slice(-10), stream: false }),
    });
    const data = await res.json();
    
    // 移除 loading
    const msgs = document.getElementById('messages');
    const loading = msgs.querySelector('.loading');
    if (loading) loading.remove();
    
    const answer = data.answer || '未获取到回答';
    const mode = data.mode || 'unknown';
    const sources = data.sources || [];
    
    // 构建来源信息
    let sourceInfo = '';
    if (sources.length > 0) {
      sourceInfo = '<div style="margin-top:8px">';
      sources.slice(0, 3).forEach(s => {
        const name = s.file_name || s.title || s.file || '来源';
        sourceInfo += `<div class="source-card" onclick="window.open('${s.url||'#'}','_blank')">📎 ${name.substring(0,40)}</div>`;
      });
      sourceInfo += '</div>';
    }
    
    addMessage('assistant', renderMarkdown(answer) + sourceInfo);
    chatHistory.push({ role: 'assistant', content: answer });
    saveChatHistory();
    
  } catch(e) {
    const msgs = document.getElementById('messages');
    const loading = msgs.querySelector('.loading');
    if (loading) loading.remove();
    addMessage('assistant', '❌ 请求失败: ' + e.message);
  }
}

function addMessage(role, content, isLoading=false) {
  const msgs = document.getElementById('messages');
  const div = document.createElement('div');
  div.className = 'msg ' + role + (isLoading ? ' loading' : '');
  div.innerHTML = content;
  msgs.appendChild(div);
  msgs.scrollTop = msgs.scrollHeight;
  return div;
}

function quickAsk(q) {
  document.getElementById('chat-input').value = q;
  switchPanel('chat');
  sendMessage();
}

function clearChat() {
  document.getElementById('messages').innerHTML = '<div class="msg system">对话已清空。有什么可以帮你？</div>';
  chatHistory = [];
  localStorage.removeItem('fuxi-chat-history');
}

function saveChatHistory() {
  try {
    localStorage.setItem('fuxi-chat-history', JSON.stringify(chatHistory.slice(-20)));
    renderHistoryList();
  } catch(e) {}
}

function renderHistoryList() {
  const el = document.getElementById('chat-history');
  const items = chatHistory.filter(h => h.role === 'user').slice(-15);
  el.innerHTML = items.map((h,i) => 
    `<div class="history-item" onclick="replayChat(${i})">
      <div>${h.content.substring(0,30)}…</div>
    </div>`
  ).join('');
}

function replayChat(idx) {
  switchPanel('chat');
}

// ========== 简单 Markdown 渲染 ==========
function renderMarkdown(text) {
  if (!text) return '';
  return text
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    .replace(/`(.+?)`/g, '<code>$1</code>')
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    .replace(/^# (.+)$/gm, '<h1>$1</h1>')
    .replace(/^- (.+)$/gm, '<li>$1</li>')
    .replace(/\n\n/g, '<br><br>');
}

// ========== 常用工具 ==========
async function loadTools() {
  const el = document.getElementById('tools-grid');
  try {
    const res = await fetch(API + '/api/tools');
    const data = await res.json();
    const tools = data.tools || [];
    el.innerHTML = tools.map(t => `
      <div style="background:var(--bg-chat);border:1px solid var(--orange-border);border-radius:var(--radius);padding:20px;text-align:center;cursor:pointer;transition:all .2s"
           onmouseover="this.style.borderColor='var(--orange)'" onmouseout="this.style.borderColor='var(--orange-border)'"
           onclick="window.open('${t.url||'#'}','_blank')">
        <div style="font-size:32px">${t.icon||'🔧'}</div>
        <div style="font-weight:600;margin-top:8px;font-size:13px">${t.name||''}</div>
        <div style="font-size:11px;color:var(--text-dim);margin-top:4px">${t.desc||''}</div>
      </div>
    `).join('');
  } catch(e) {
    el.innerHTML = '<div style="color:var(--text-dim)">加载失败</div>';
  }
}

// ========== 常见问题 ==========
async function loadFAQ() {
  const el = document.getElementById('faq-list');
  try {
    const res = await fetch(API + '/api/faq');
    const data = await res.json();
    const faqs = data.faqs || data.faq || [];
    el.innerHTML = faqs.length === 0 
      ? '<div style="color:var(--text-dim)">暂无常见问题</div>'
      : faqs.map(f => `
        <div style="background:var(--bg-chat);border:1px solid var(--orange-border);border-radius:var(--radius);padding:16px;margin-bottom:10px;cursor:pointer"
             onclick="switchPanel('chat');document.getElementById('chat-input').value='${f.question||''}';sendMessage()">
          <div style="font-weight:600;color:var(--text)">${f.question||''}</div>
          <div style="font-size:12px;color:var(--text-dim);margin-top:4px">${(f.answer||'').substring(0,80)}…</div>
        </div>
      `).join('');
  } catch(e) {
    el.innerHTML = '<div style="color:var(--text-dim)">加载失败</div>';
  }
}

// ========== 用户上传 ==========
async function userUpload(fileList) {
  const status = document.getElementById('upload-status');
  const files = Array.from(fileList);
  
  for (const file of files) {
    status.textContent = `上传中: ${file.name}…`;
    try {
      const form = new FormData();
      form.append('file', file);
      const res = await fetch(API + '/api/upload', {
        method: 'POST',
        body: form,
        headers: { 'x-admin-token': adminToken },
      });
      const data = await res.json();
      status.textContent = data.ok ? `✅ ${file.name} 上传成功` : `❌ ${file.name}: ${data.error||'失败'}`;
    } catch(e) {
      status.textContent = `❌ ${file.name} 上传失败`;
    }
  }
}

// 上传拖拽
document.addEventListener('DOMContentLoaded', () => {
  const zone = document.getElementById('user-upload-zone');
  if (zone) {
    zone.addEventListener('dragover', e => { e.preventDefault(); zone.style.borderColor = 'var(--orange)'; });
    zone.addEventListener('dragleave', () => zone.style.borderColor = 'var(--orange)');
    zone.addEventListener('drop', e => { e.preventDefault(); userUpload(e.dataTransfer.files); });
  }
  
  // 恢复历史
  try {
    const saved = localStorage.getItem('fuxi-chat-history');
    if (saved) chatHistory = JSON.parse(saved);
    renderHistoryList();
  } catch(e) {}
  
  // 自动调整 textarea 高度
  const ta = document.getElementById('chat-input');
  ta.addEventListener('input', () => {
    ta.style.height = 'auto';
    ta.style.height = Math.min(ta.scrollHeight, 120) + 'px';
  });
});
</script>
</body>
</html>
