<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>伏羲 4.2 · 内世界</title>
<style>
:root {
  --bg: #0a0a0f;
  --bg-card: #12121a;
  --border: rgba(212,168,67,0.15);
  --border-active: rgba(212,168,67,0.4);
  --gold: #d4a843;
  --gold-dim: rgba(212,168,67,0.6);
  --text: #c8c4b8;
  --text-dim: #6b6658;
  --wood: #4a9e6e;
  --fire: #c2593a;
  --earth: #c4a45a;
  --metal: #d4c5b9;
  --water: #3a5070;
  --radius: 10px;
}
* { box-sizing:border-box; margin:0; padding:0; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: "Microsoft YaHei", "PingFang SC", system-ui, sans-serif;
  min-height: 100vh;
  display: flex;
}
h1,h2,h3{font-weight:400;letter-spacing:.04em;}

/* 左侧经络流注条 */
.flow-bar {
  width: 72px;
  background: #0d0d15;
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20px 0;
  gap: 4px;
}
.flow-hour {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: #161620;
  border: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  color: var(--text-dim);
  cursor: pointer;
  transition: all .3s;
  position: relative;
}
.flow-hour.active {
  border-color: var(--gold);
  color: var(--gold);
  box-shadow: 0 0 12px rgba(212,168,67,0.3);
  animation: pulse-gold 2s infinite;
}
.flow-hour:hover { border-color: var(--gold-dim); color: var(--gold-dim); }
.flow-label {
  writing-mode: vertical-rl;
  font-size: 10px;
  color: var(--text-dim);
  letter-spacing: .1em;
  margin-top: 12px;
}

/* 主区域 */
.main {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 24px 32px;
  gap: 20px;
  max-width: 960px;
  margin: 0 auto;
}

/* 顶栏 */
.tbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--border);
}
.tbar h1 {
  font-size: 22px;
  color: var(--gold);
  letter-spacing: .08em;
}
.tbar h1 span { color: var(--text-dim); font-size: 14px; margin-left: 8px; }
.tbar-time {
  font-size: 12px;
  color: var(--text-dim);
  text-align: right;
}
.tbar-stem {
  font-size: 28px;
  color: var(--gold);
  font-weight: 600;
}

/* 九宫格 */
.grid-9 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: repeat(3, 1fr);
  gap: 2px;
  aspect-ratio: 1;
  max-height: 520px;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  background: var(--border);
}
.cell {
  background: var(--bg-card);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 5px;
  cursor: pointer;
  transition: all .25s;
  position: relative;
  overflow: hidden;
}
.cell:hover {
  background: #1a1a28;
  border-color: var(--border-active);
}
.cell .gua {
  font-family: "SimSun", "Noto Serif CJK SC", serif;
  font-size: 32px;
  color: var(--gold);
  opacity: .85;
}
.cell .element-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  position: absolute;
  top: 10px;
  right: 10px;
}
.cell .ele-wood { background: var(--wood); }
.cell .ele-fire { background: var(--fire); }
.cell .ele-earth { background: var(--earth); }
.cell .ele-metal { background: var(--metal); }
.cell .ele-water { background: var(--water); }
.cell .stem-tag {
  font-size: 11px;
  color: var(--text-dim);
  letter-spacing: .06em;
}
.cell .pulse {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  position: absolute;
  bottom: 12px;
}
.cell .pulse-online {
  background: var(--gold);
  animation: breathe 2.5s ease-in-out infinite;
}
.cell .pulse-warn {
  background: var(--fire);
  animation: breathe 1.2s ease-in-out infinite;
}
.cell .pulse-offline {
  background: #333;
}
.cell.center-cell {
  background: #18182a;
  border: 1px solid var(--border-active);
}
.center-cell .gua { font-size: 24px; }

@keyframes breathe {
  0%,100% { opacity: 1; box-shadow: 0 0 4px rgba(212,168,67,0.4); }
  50% { opacity: .5; box-shadow: 0 0 12px rgba(212,168,67,0.7); }
}
@keyframes pulse-gold {
  0%,100% { box-shadow: 0 0 8px rgba(212,168,67,0.2); }
  50% { box-shadow: 0 0 20px rgba(212,168,67,0.5); }
}

/* 底部面板 */
.panels {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}
.panel {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 16px;
}
.panel h3 {
  font-size: 13px;
  color: var(--gold);
  margin-bottom: 10px;
  letter-spacing: .08em;
}

/* 五行轮盘 */
.wuxing-ring {
  display: flex;
  align-items: center;
  gap: 16px;
}
.wx-hub {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  border: 2px solid var(--border-active);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  color: var(--gold);
  animation: spin-slow 20s linear infinite;
}
@keyframes spin-slow { to { transform: rotate(360deg); } }
.wx-spokes {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6px;
  font-size: 11px;
}
.wx-spoke { padding: 4px 8px; border-radius: 4px; background: #1a1a28; }
.wx-spoke .arrow { color: var(--gold-dim); margin: 0 2px; }

/* 跑马灯状态 */
.marquee {
  font-size: 11px;
  color: var(--text-dim);
  margin-top: 8px;
  overflow: hidden;
}
.marquee span { display: inline-block; white-space: nowrap; }

@media (max-width: 720px) {
  .flow-bar { display: none; }
  .main { padding: 16px; }
  .panels { grid-template-columns: 1fr; }
  .grid-9 { max-height: 360px; }
  .cell .gua { font-size: 24px; }
}
</style>
</head>
<body>

<aside class="flow-bar" id="flowBar"></aside>

<main class="main">
  <div class="tbar">
    <div>
      <h1>伏羲 4.2 <span>内世界</span></h1>
    </div>
    <div style="text-align:right">
      <div class="tbar-stem" id="currentStem">—</div>
      <div class="tbar-time" id="currentHour">—</div>
    </div>
  </div>

  <div class="grid-9" id="baguaGrid"></div>

  <div class="panels">
    <div class="panel" id="panelWuxing">
      <h3>五行生克</h3>
      <div class="wuxing-ring"><div class="wx-hub">五<br>行</div></div>
      <div class="wx-spokes" id="wxSpokes"></div>
    </div>
    <div class="panel" id="panelMeridian">
      <h3>经络流注</h3>
      <div class="marquee" id="meridianInfo">—</div>
    </div>
  </div>
</main>

<script>
const API = '/api/v2/status';

const BAGUA_POS = [
  {id:'lung',    palace:4, row:0, col:0, gua:'☴', glyph:'巽', stem:'乙', el:'wood',   dir:'东南'},
  {id:'heart',   palace:9, row:0, col:1, gua:'☲', glyph:'离', stem:'丙', el:'fire',   dir:'南'},
  {id:'spleen',  palace:2, row:0, col:2, gua:'☷', glyph:'坤', stem:'己', el:'earth',  dir:'西南'},
  {id:'liver',   palace:3, row:1, col:0, gua:'☳', glyph:'震', stem:'甲', el:'wood',   dir:'东'},
  {id:'stomach', palace:5, row:1, col:1, gua:'⊕',  glyph:'中宫',stem:'戊', el:'earth', dir:'中'},
  {id:'nose',    palace:7, row:1, col:2, gua:'☱', glyph:'兑', stem:'辛', el:'metal',  dir:'西'},
  {id:'skin',    palace:8, row:2, col:0, gua:'☶', glyph:'艮', stem:'庚', el:'earth',  dir:'东北'},
  {id:'kidney',  palace:1, row:2, col:1, gua:'☵', glyph:'坎', stem:'癸', el:'water',  dir:'北'},
  {id:'brain',   palace:6, row:2, col:2, gua:'☰', glyph:'乾', stem:'丁', el:'metal',  dir:'西北'},
];

const STEMS = {甲:{el:'木',yy:'阳'},乙:{el:'木',yy:'阴'},丙:{el:'火',yy:'阳'},丁:{el:'火',yy:'阴'},
戊:{el:'土',yy:'阳'},己:{el:'土',yy:'阴'},庚:{el:'金',yy:'阳'},辛:{el:'金',yy:'阴'},
壬:{el:'水',yy:'阳'},癸:{el:'水',yy:'阴'}};

const HOUR_CHINESE = {0:'子',1:'丑',2:'丑',3:'寅',4:'寅',5:'卯',6:'卯',7:'辰',8:'辰',9:'巳',10:'巳',11:'午',12:'午',13:'未',14:'未',15:'申',16:'申',17:'酉',18:'酉',19:'戌',20:'戌',21:'亥',22:'亥',23:'子'};

const SHENG = {木:'火',火:'土',土:'金',金:'水',水:'木'};
const KE = {木:'土',火:'金',土:'水',金:'木',水:'火'};

function elColor(el) {
  return {'木':'var(--wood)','火':'var(--fire)','土':'var(--earth)','金':'var(--metal)','水':'var(--water)'}[el]||'#666';
}

function buildFlowBar() {
  const bar = document.getElementById('flowBar');
  for (let h = 0; h < 24; h += 2) {
    const div = document.createElement('div');
    div.className = 'flow-hour';
    div.textContent = HOUR_CHINESE[h];
    div.title = `${HOUR_CHINESE[h]}时 (${String(h).padStart(2,'0')}:00-${String(h+2).padStart(2,'0')}:00)`;
    div.setAttribute('data-hour', h);
    bar.appendChild(div);
  }
}

function highlightFlowHour() {
  const h = new Date().getHours();
  const block = Math.floor(h / 2) * 2;
  document.querySelectorAll('.flow-hour').forEach(el => {
    el.classList.toggle('active', parseInt(el.getAttribute('data-hour')) === block);
  });
}

function buildGrid() {
  const grid = document.getElementById('baguaGrid');
  let cells = {};
  BAGUA_POS.forEach(bp => {
    const cell = document.createElement('div');
    cell.className = 'cell';
    if (bp.id === 'stomach') cell.className += ' center-cell';
    cell.style.gridRow = bp.row + 1;
    cell.style.gridCol = bp.col + 1;
    cell.title = `${bp.glyph} ${bp.gua} · ${bp.dir} · ${bp.el}`;
    cell.innerHTML = `
      <span class="element-dot ele-${bp.el}"></span>
      <span class="gua">${bp.gua}</span>
      <span class="stem-tag">${bp.stem} · ${bp.el}</span>
      <span class="pulse pulse-offline"></span>`;
    cell.setAttribute('data-organ', bp.id);
    cell.onclick = () => showDetail(bp);
    cells[bp.id] = cell;
    grid.appendChild(cell);
  });
  return cells;
}

let cellsMap;

function showDetail(bp) {
  alert(`【${bp.glyph}位 · ${bp.gua}】${bp.dir}方 · ${bp.el}行\n天干：${bp.stem}\n洛书数：${bp.palace}`);
}

async function refreshStatus() {
  try {
    const r = await fetch(API);
    const d = await r.json();
    if (!d.ok) return;

    const bagua = d.bagua || {};
    // 更新九宫格
    BAGUA_POS.forEach(bp => {
      const cell = cellsMap[bp.id];
      if (!cell) return;
      const org = bagua[bp.id] || {};
      const pulse = cell.querySelector('.pulse');
      pulse.className = 'pulse';
      if (org.alive === false) pulse.className += ' pulse-offline';
      else if (org.qi !== undefined && org.qi < 50) pulse.className += ' pulse-warn';
      else pulse.className += ' pulse-online';
    });

    // 更新天干
    const bal = d.balance || {};
    const stemInfo = bal.stem_scheduler || {};
    document.getElementById('currentStem').textContent = stemInfo.current_stem || '—';
    const h = new Date().getHours();
    document.getElementById('currentHour').textContent = `${HOUR_CHINESE[h]}时 · ${STEMS[stemInfo.current_stem]?.el || ''}`;

    // 更新整体健康分
    document.querySelector('.tbar h1 span').textContent = `脉象 ${d.health_score || '—'}`;

    // 五行生克
    const fe = bal.five_elements || {};
    buildWuxingSpokes(fe);

    // 经络流注
    const mr = bal.meridian_rhythm || {};
    document.getElementById('meridianInfo').innerHTML = 
      `<span>🕐 ${mr.current_meridian || '—'} · ${mr.chinese_hour || ''}时当令 · 脉次 ${mr.pulse_count || 0}</span>`;

    highlightFlowHour();
  } catch (e) { console.error(e); }
}

function buildWuxingSpokes(fe) {
  const spokes = document.getElementById('wxSpokes');
  const elStatus = fe.status || {};
  const imbalances = fe.imbalances || [];
  let html = '';
  for (const [el, data] of Object.entries(elStatus)) {
    const load = (data.load || 0) * 100;
    html += `<div class="wx-spoke" style="border-left:2px solid ${elColor(el)}; color:${elColor(el)}">
      ${el} ${load.toFixed(0)}%</div>`;
  }
  html += '<div class="wx-spoke" style="grid-column:1/-1;font-size:10px;color:var(--text-dim)">';
  html += '木→火→土→金→水→木';
  html += '</div>';
  if (imbalances.length > 0) {
    html += `<div class="wx-spoke" style="grid-column:1/-1;color:var(--fire);font-size:10px">⚠ 失衡: ${imbalances.map(i=>i.element).join(',')}</div>`;
  }
  spokes.innerHTML = html;
}

// 初始化
buildFlowBar();
cellsMap = buildGrid();
refreshStatus();
setInterval(refreshStatus, 10000);
highlightFlowHour();
setInterval(highlightFlowHour, 60000);
</script>
</body>
</html>
