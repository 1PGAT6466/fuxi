<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>伏羲 4.2 · 内世界</title>
<style>
:root{--bg:#FFF8F2;--card:#FFF;--side:#FFF0E5;--o:#FF7A00;--od:rgba(255,122,0,0.06);--ob:rgba(255,122,0,0.10);--t:#2D1A0A;--td:#9B7A5A;--r:14px}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--t);font-family:"Microsoft YaHei","PingFang SC",system-ui,sans-serif;display:flex;min-height:100vh}
h1,h2,h3{font-weight:600;letter-spacing:.02em}

.sidebar{width:220px;background:var(--side);border-right:1px solid var(--ob);display:flex;flex-direction:column;position:sticky;top:0;height:100vh;overflow-y:auto}
.s-logo{padding:20px 18px 16px;border-bottom:1px solid var(--ob)}
.s-logo h1{font-size:18px;color:var(--o)}
.s-logo span{font-size:11px;color:var(--td);font-weight:400}
.nav-item{padding:12px 18px;cursor:pointer;font-size:13px;color:var(--td);border-left:3px solid transparent;transition:all .2s;display:flex;align-items:center;gap:8px}
.nav-item:hover{background:var(--od);color:var(--t)}
.nav-item.active{background:var(--od);color:var(--o);border-left-color:var(--o);font-weight:600}
.cat-sec{padding:12px 18px;border-top:1px solid var(--ob);font-size:11px;color:var(--td);flex:1;overflow-y:auto}
.cat-sec .t{font-weight:600;margin-bottom:6px}
.cat-tag{display:flex;justify-content:space-between;padding:4px 0;cursor:pointer;font-size:11px}
.cat-tag:hover{color:var(--o)}
.cat-tag.active{color:var(--o);font-weight:600}

.main{flex:1;padding:28px 36px;overflow-y:auto;max-height:100vh}
.card{background:var(--card);border-radius:var(--r);border:1px solid var(--ob);padding:22px 24px;margin-bottom:18px;box-shadow:0 1px 8px rgba(255,122,0,0.06)}
.card h3{font-size:15px;color:var(--o);margin-bottom:14px;display:flex;align-items:center;gap:8px}

.up-zone{border:2px dashed #FFD4A0;border-radius:var(--r);padding:28px;text-align:center;cursor:pointer;background:#FFFBF7}
.up-zone:hover{background:#FFF5E8;border-color:var(--o)}
.up-zone.dragover{background:#FFF0E0;border-color:var(--o)}
.up-zone p{color:var(--td);font-size:13px;margin-top:6px}

input[type=file]{display:none}
.item-row{display:flex;align-items:center;justify-content:space-between;padding:9px 12px;border-bottom:1px solid rgba(0,0,0,0.04);font-size:13px;gap:10px}
.item-row:last-child{border-bottom:none}
.item-name{flex:1;color:var(--t);cursor:pointer;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.item-name:hover{color:var(--o)}
.item-cat{color:var(--o);font-size:10px;background:var(--od);padding:2px 8px;border-radius:8px;white-space:nowrap}
.item-actions{display:flex;gap:4px}
.abtn{padding:4px 10px;border-radius:12px;border:1px solid var(--ob);background:#fff;cursor:pointer;font-size:10px;color:var(--td);font-family:inherit}
.abtn:hover{background:var(--od);color:var(--o)}
.abtn.danger:hover{background:#FFF0F0;color:#d33}

.pg{display:flex;justify-content:center;gap:6px;margin-top:16px}
.pg-btn{padding:6px 14px;border-radius:14px;border:1px solid var(--ob);background:#fff;cursor:pointer;font-size:12px;color:var(--td);font-family:inherit}
.pg-btn:hover{background:var(--od);color:var(--o)}
.pg-btn.active{background:var(--o);color:#fff;border-color:var(--o)}
.pg-info{font-size:12px;color:var(--td);text-align:center;margin-top:8px}

.sbar{display:flex;gap:8px;margin-bottom:14px}
.sbar input{flex:1;padding:9px 14px;border-radius:20px;border:1px solid var(--ob);background:var(--bg);font-size:13px;color:var(--t);outline:none;font-family:inherit}
.sbar input:focus{border-color:var(--o)}
.sbar button{padding:9px 18px;border-radius:20px;background:var(--o);border:none;color:#fff;cursor:pointer;font-size:12px;font-weight:600;font-family:inherit}

.sgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
.stat{background:#FFFBF7;border-radius:var(--r);border:1px solid var(--ob);padding:14px;text-align:center}
.sv{font-size:24px;font-weight:700;color:var(--o)}
.sl{font-size:11px;color:var(--td);margin-top:2px}

.bagua-g{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.bc{padding:12px 8px;border-radius:10px;background:#FFFBF7;text-align:center;border:1px solid var(--ob);font-size:12px}
.bc .sym{font-size:26px;display:block}
.bc.alive{border-color:var(--o);background:var(--od)}
.bc.dead{opacity:0.35}
.bc.center{grid-column:2;background:#FFF8F0}

.modal-o{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.35);z-index:200;align-items:center;justify-content:center}
.modal-o.show{display:flex}
.modal{background:#fff;border-radius:var(--r);padding:24px;max-width:700px;max-height:80vh;overflow-y:auto;width:90%;box-shadow:0 8px 32px rgba(0,0,0,0.12)}
.modal h3{color:var(--o);margin-bottom:12px}
.modal pre{white-space:pre-wrap;font-size:12px;line-height:1.6;max-height:400px;overflow-y:auto;background:#FFFBF7;padding:12px;border-radius:8px}
.modal-close{float:right;background:none;border:none;font-size:20px;cursor:pointer;color:var(--td)}

.empt{text-align:center;padding:36px;color:var(--td);font-size:13px}
.toast{position:fixed;bottom:24px;right:24px;background:var(--o);color:#fff;padding:10px 22px;border-radius:20px;font-size:12px;z-index:300;opacity:0;transition:opacity .3s}
.toast.show{opacity:1}
</style>
</head>
<body>

<nav class="sidebar">
<div class="s-logo"><h1>☰ 伏羲 4.2 <span>内世界</span></h1></div>
<div class="nav-item active" onclick="st('upload')">📤 文件管理</div>
<div class="nav-item" onclick="st('wiki')">🧠 Wiki 知识</div>
<div class="nav-item" onclick="st('graph')">🕸️ 知识图谱</div>
<div class="nav-item" onclick="st('eval')">📊 搜索评测</div>
<div class="nav-item" onclick="st('feedback')">💬 用户反馈</div>
<div class="nav-item" onclick="st('status')">⚙️ 系统状态</div>
<div style="flex:1"></div>
<div class="cat-sec" id="cats"><div class="t">📂 分类筛选</div><div class="cat-tag active" data-cat="" onclick="fc('')"><span>全部</span><span class="cat-cnt" id="cat-all">-</span></div><div id="cat-inner"></div></div>
</nav>

<main class="main" id="mc"></main>
<div class="modal-o" id="mo"><div class="modal"><button class="modal-close" onclick="cm()">✕</button><div id="mb"></div></div></div>
<div class="toast" id="toast"></div>

<script>
const A='',PS=50,tk='polygon-admin-2024';
let ct='upload',cc='',cp=1,af=[],aw=[];
function tm(m){const e=document.getElementById('toast');e.textContent=m;e.classList.add('show');setTimeout(()=>e.classList.remove('show'),2200)}
function cm(){document.getElementById('mo').classList.remove('show')}
function es(s){const d=document.createElement('div');d.textContent=s;return d.innerHTML}
async function api(u,o={}){const r=await fetch(A+u,{...o,headers:{'x-admin-token':tk,...(o.headers||{})}});if(!r.ok)throw new Error(r.status);return r.json()}

function st(t){ct=t;cp=1;document.querySelectorAll('.nav-item').forEach(b=>b.classList.remove('active'));event.target.classList.add('active');
if(t==='upload')lf();else if(t==='wiki')lw();else if(t==='graph')lg();else if(t==='eval')re();else if(t==='feedback')rf();else if(t==='status')rs()}
function fc(c){cc=c;cp=1;uc();ct==='wiki'?rww():rfw()}

function uc(){const items=ct==='wiki'?aw:af;const cnts={};items.forEach(i=>{const c=i.category||'未分类';cnts[c]=(cnts[c]||0)+1});document.getElementById('cat-all').textContent=items.length;
let h='';Object.entries(cnts).sort((a,b)=>b[1]-a[1]).forEach(([c,n])=>h+=`<div class="cat-tag${cc===c?' active':''}" data-cat="${es(c)}" onclick="fc('${es(c)}')"><span>📂 ${es(c)}</span><span style="font-size:10px;color:var(--td)">${n}</span></div>`);document.getElementById('cat-inner').innerHTML=h}

// File
var _lfLastHash='';async function lf(){document.getElementById('mc').innerHTML='<div class="empt">加载…</div>';
try{const d=await api('/api/documents?page_size=9999');af=d.files||d.documents||[];if(af.length&&!af[0].file_name)af=Object.values(af)}catch(e){af=[]}uc();rfw()}
function rfw(){const m=document.getElementById('mc');let fs=cc?af.filter(f=>(f.category||'未分类')===cc):af;const tot=fs.length,tp=Math.ceil(tot/PS)||1;if(cp>tp)cp=tp;fs=fs.slice((cp-1)*PS,cp*PS);
const pg=tp<=1?'':`<div class="pg"><button class="pg-btn" onclick="cp=Math.max(1,cp-1);rfw()" ${cp<=1?'disabled':''}>‹</button>${Array.from({length:Math.min(tp,10)},(_,i)=>i+1).map(p=>`<button class="pg-btn${p===cp?' active':''}" onclick="cp=${p};rfw()">${p}</button>`).join('')}<button class="pg-btn" onclick="cp=Math.min(tp,cp+1);rfw()" ${cp>=tp?'disabled':''}>›</button></div><div class="pg-info">${tot} 条 · 第 ${cp}/${tp} 页 · 每页${PS}条</div>`;
m.innerHTML=`<div class="card"><h3>📤 文件管理</h3><div class="up-zone" id="uz" onclick="document.getElementById('fi').click()"><div style="font-size:36px">📁</div><p>点击或拖拽文件上传</p><p style="font-size:11px;color:#C8A888">PDF/DOCX/XLSX/TXT/MD/图片</p>
        <p style="margin-top:8px"><button class="abtn" onclick="event.stopPropagation();document.getElementById('ffi').click()" style="padding:6px 18px;font-size:12px">📁 上传文件夹</button></p></div><input type="file" id="fi" multiple onchange="up(this.files)" accept=".pdf,.docx,.doc,.xlsx,.xls,.txt,.md,.csv,.json,.xml,.html,.htm,.jpg,.jpeg,.png,.gif,.bmp,.svg">
      <input type="file" id="ffi" webkitdirectory multiple onchange="up(this.files)" style="display:none"></div><div class="card"><h3>📋 文件列表 <span style="font-size:11px;color:var(--td)">(${tot} 个)</span></h3><div class="sbar"><input type="text" id="fs" placeholder="搜索文件名…" oninput="sf()"></div><div id="fl">${tot===0?'<div class="empt">暂无文件</div>':''}</div>${pg}</div>`;
const z=document.getElementById('uz');if(z){z.addEventListener('dragover',e=>{e.preventDefault();z.style.borderColor='var(--o)'});z.addEventListener('dragleave',()=>z.style.borderColor='#FFD4A0');z.addEventListener('drop',e=>{e.preventDefault();z.style.borderColor='#FFD4A0';up(e.dataTransfer.files)})}
if(tot>0)rfl(fs)}
function sf(){const q=document.getElementById('fs').value.toLowerCase();let fs=cc?af.filter(f=>(f.category||'未分类')===cc):af;if(q)fs=fs.filter(f=>(f.file_name||f.name||'').toLowerCase().includes(q));cp=1;rfl(fs.slice(0,PS))}
function rfl(fs){const el=document.getElementById('fl');if(!el)return;el.innerHTML=fs.map(f=>{const n=f.file_name||f.name||'?',c=f.category||'未分类',h=f.file_hash||f.hash||'';return`<div class="item-row"><span class="item-name" onclick="vf('${h}')">📄 ${es(n)}</span><span class="item-cat">${es(c)}</span><div class="item-actions"><button class="abtn" onclick="vf('${h}')">👁</button><button class="abtn" onclick="dfh('${h}')">⬇</button><button class="abtn danger" onclick="def('${h}','${es(n)}')">🗑</button></div></div>`}).join('')}
async function up(fl){for(const f of Array.from(fl)){tm('上传: '+f.name);const fd=new FormData();fd.append('file',f);try{const r=await fetch(A+'/api/upload',{method:'POST',body:fd,headers:{'x-admin-token':tk}});const d=await r.json();tm(d.ok?'✅ '+f.name:'❌ '+(d.error||'失败'))}catch(e){tm('❌ '+f.name)}}setTimeout(lf,1500)}
function dfh(h){window.open(A+'/api/download/'+h,'_blank')}
async function vf(h){const m=document.getElementById('mo');document.getElementById('mb').innerHTML='<div class="empt">加载…</div>';m.classList.add('show');try{const d=await api('/api/view/'+h);document.getElementById('mb').innerHTML=`<h3>📄 文件内容</h3><pre>${es(d.content||d.html||d.text||'无内容')}</pre>`}catch(e){document.getElementById('mb').innerHTML='<h3>❌ 加载失败</h3>'}}
async function def(h,n){if(!confirm('删除 "'+n+'"？'))return;try{await api('/api/documents/'+h,{method:'DELETE'});tm('已删除');lf()}catch(e){tm('删除失败')}}

// Wiki
async function lw(){document.getElementById('mc').innerHTML='<div class="empt">加载…</div>';
try{const d=await api('/api/wiki/pages?limit=9999');aw=d.pages||d.data||[]}catch(e){aw=[]}uc();rww()}
function rww(){const m=document.getElementById('mc');let ps=cc?aw.filter(w=>(w.category||'未分类')===cc):aw;const tot=ps.length,tp=Math.ceil(tot/PS)||1;if(cp>tp)cp=tp;ps=ps.slice((cp-1)*PS,cp*PS);
const pg=tp<=1?'':`<div class="pg"><button class="pg-btn" onclick="cp=Math.max(1,cp-1);rww()" ${cp<=1?'disabled':''}>‹</button>${Array.from({length:Math.min(tp,10)},(_,i)=>i+1).map(p=>`<button class="pg-btn${p===cp?' active':''}" onclick="cp=${p};rww()">${p}</button>`).join('')}<button class="pg-btn" onclick="cp=Math.min(tp,cp+1);rww()" ${cp>=tp?'disabled':''}>›</button></div><div class="pg-info">${tot} 条 · 第 ${cp}/${tp} 页 · 每页${PS}条</div>`;
m.innerHTML=`<div class="card"><h3>🧠 Wiki 知识库 <span style="font-size:11px;color:var(--td)">(${tot} 条目)</span></h3><div class="sbar"><input type="text" id="ws" placeholder="搜索…" oninput="sw()"></div><div id="wl">${tot===0?'<div class="empt">暂无 Wiki</div>':''}</div>${pg}</div>`;if(tot>0)rwl(ps)}
function sw(){const q=document.getElementById('ws').value.toLowerCase();let ps=cc?aw.filter(w=>(w.category||'未分类')===cc):aw;if(q)ps=ps.filter(w=>(w.title||'').toLowerCase().includes(q)||(w.summary||'').toLowerCase().includes(q));cp=1;rwl(ps.slice(0,PS))}
function rwl(ps){const el=document.getElementById('wl');if(!el)return;el.innerHTML=ps.map(w=>`<div class="item-row"><span class="item-name" onclick="vw('${w.id}')">🧠 ${es(w.title||'未命名')}</span><span class="item-cat">${es(w.category||'未分类')}</span><div class="item-actions"><button class="abtn" onclick="vw('${w.id}')">👁</button><button class="abtn danger" onclick="dew('${w.id}','${es(w.title||'')}')">🗑</button></div></div>`).join('')}
async function vw(id){const m=document.getElementById('mo');m.classList.add('show');document.getElementById('mb').innerHTML='<div class="empt">加载…</div>';try{const d=await api('/api/wiki/page/'+id);document.getElementById('mb').innerHTML=`<h3>🧠 ${es(d.title||'')}</h3><p style="color:var(--td);font-size:11px;margin-bottom:10px">分类: ${es(d.category||'未分类')} | 质量: ${d.quality_score||'N/A'}</p><div style="line-height:1.8;font-size:13px">${d.content||d.summary||'无内容'}</div>`}catch(e){document.getElementById('mb').innerHTML='<h3>❌ 失败</h3>'}}
async function dew(id,t){if(!confirm('删除 "'+t+'"？'))return;try{await api('/api/wiki/page/'+id,{method:'DELETE'});tm('已删除');lw()}catch(e){tm('失败')}}

// Graph
async function lg(){document.getElementById('mc').innerHTML='<div class="empt">加载…</div>';
try{const d=await api('/api/graph');const nodes=d.nodes||{},edges=d.edges||[];const cats={};Object.values(nodes).forEach(n=>{const c=n.type||n.category||'其他';cats[c]=(cats[c]||0)+1});
document.getElementById('mc').innerHTML=`<div class="card"><h3>🕸️ 知识图谱</h3><div class="sgrid"><div class="stat"><div class="sv">${Object.keys(nodes).length}</div><div class="sl">实体节点</div></div><div class="stat"><div class="sv">${edges.length}</div><div class="sl">关系边</div></div><div class="stat"><div class="sv">${Object.keys(cats).length}</div><div class="sl">分类数</div></div><div class="stat"><div class="sv">${nodes._stats?.total_entities||0}</div><div class="sl">链接</div></div></div></div>${Object.keys(cats).length===0?'<div class="card"><h3>📂 分类浏览</h3><div class="empt">暂无数据</div></div>':'<div class="card"><h3>📂 分类浏览</h3>'+Object.entries(cats).sort((a,b)=>b[1]-a[1]).map(([cat,cnt])=>{const items=Object.entries(nodes).filter(([_,n])=>(n.type||n.category||'其他')===cat).slice(0,8);return`<div style="margin-bottom:12px"><span style="color:var(--o);font-weight:600;font-size:13px">📂 ${es(cat)} (${cnt})</span><div style="margin-top:4px">${items.map(([name])=>`<span style="display:inline-block;background:var(--od);color:var(--o);padding:3px 10px;border-radius:14px;margin:2px;font-size:11px">${es(name)}</span>`).join('')}${cnt>8?` <span style="color:var(--td);font-size:11px">…${cnt}</span>`:''}</div></div>`}).join('')+'</div>'}`}catch(e){document.getElementById('mc').innerHTML='<div class="card"><h3>🕸️ 知识图谱</h3><div class="empt">暂不可用</div></div>'}}

// Eval
function re(){document.getElementById('mc').innerHTML=`<div class="card"><h3>📊 搜索评测</h3><p style="color:var(--td);font-size:12px;margin-bottom:12px"><a href="/dashboard" target="_blank" style="color:var(--o)">完整仪表板 →</a></p><div class="sbar"><input type="text" id="eq" placeholder="查询…" onkeypress="if(event.key==='Enter')rune()"><button onclick="rune()">🔍</button></div><div id="er"></div></div>`}
async function rune(){const q=document.getElementById('eq').value.trim();if(!q)return;const el=document.getElementById('er');el.innerHTML='<div class="empt">评测…</div>';const t0=performance.now();
try{const d=await api('/api/search?q='+encodeURIComponent(q)+'&top_k=10');const ms=(performance.now()-t0).toFixed(0);const ch=d.results||d.chunk_results||[],wr=d.wiki_results||[];
let h=`<p style="color:var(--td);font-size:12px;margin-top:8px">${ms}ms | 文档:${ch.length} Wiki:${wr.length}</p>`;
if(wr.length>0)h+='<h4 style="color:var(--o);margin-top:10px;font-size:13px">🧠 Wiki</h4>'+wr.map(w=>`<div class="item-row"><span class="item-name">🧠 ${es(w._wiki_title||w.text||'')}</span><span style="font-size:10px;color:var(--o)">${(w.score||0).toFixed(1)}</span></div>`).join('');
h+='<h4 style="color:var(--o);margin-top:10px;font-size:13px">📄 文档</h4>';if(ch.length===0)h+='<div class="empt">无匹配</div>';else ch.slice(0,10).forEach(r=>h+=`<div class="item-row"><span class="item-name">📄 ${es((r.file_name||'来源').substring(0,35))}</span><span class="item-cat">${es(r.category||'?')}</span><span style="font-size:10px;color:var(--td)">${(r.score||0).toFixed(1)}</span></div>`);el.innerHTML=h}catch(e){el.innerHTML='<div class="empt">失败</div>'}}

// Feedback
async function rf(){document.getElementById('mc').innerHTML='<div class="empt">加载…</div>';
try{const d=await api('/api/feedback/weekly');const items=d.feedbacks||d.data||d.items||[];document.getElementById('mc').innerHTML=`<div class="card"><h3>💬 用户反馈 <span style="font-size:11px;color:var(--td)">(${items.length})</span></h3><p style="font-size:11px;color:var(--td);margin-bottom:12px">最近一周</p>${items.length===0?'<div class="empt">暂无</div>':items.slice(0,100).map(f=>`<div class="item-row"><span class="item-name">${es((f.query||f.question||'').substring(0,45))}</span><span style="font-size:10px;color:${f.useful?'var(--o)':'var(--td)'}">${f.useful?'👍':'👎'}</span></div>`).join('')}</div>`}catch(e){document.getElementById('mc').innerHTML='<div class="card"><h3>💬 用户反馈</h3><div class="empt">暂无</div></div>'}}

// Status
async function rs(){document.getElementById('mc').innerHTML='<div class="empt">加载…</div>';
try{const[v,h]=await Promise.all([api('/api/v2/status').catch(()=>({})),api('/api/health').catch(()=>({}))]);const b=v.bagua||[],ext=v.extra_organs||[],stm=(ext.find(e=>e.organ_id==='stomach')||{});
const bc=(x,id)=>{const o=b.find(bb=>bb.trigram===id)||{};return`<div class="bc${o.alive?' alive':' dead'}"><span class="sym">${x}</span>${o.organ_name||'?'}<br><span style="font-size:10px;color:var(--td)">${o.alive?'存活':'休眠'}</span></div>`};
document.getElementById('mc').innerHTML=`
<div class="card"><h3>⚙️ 系统状态</h3><div class="sgrid"><div class="stat"><div class="sv">${h.version||v.version||'4.2'}</div><div class="sl">版本</div></div><div class="stat"><div class="sv" style="color:${v.health_score>60?'var(--o)':'#d33'}">${v.health_score||0}</div><div class="sl">健康评分</div></div><div class="stat"><div class="sv">${v.alive_organs||0}/${v.total_organs_inner||0}</div><div class="sl">存活器官</div></div><div class="stat"><div class="sv">${h.chunks||v.data?.chunks||0}</div><div class="sl">文档块</div></div></div></div>

<div class="card"><h3>☯ 后天八卦九宫</h3>
<div class="bagua-g">
${bc('☴','xun')}${bc('☲','li')}${bc('☷','kun')}
${bc('☳','zhen')}<div class="bc center"><span class="sym">⊕</span>中宫·胃<br><span style="font-size:10px;color:var(--td)">${stm.alive?'存活':'休眠'}</span></div>${bc('☱','dui')}
${bc('☶','gen')}${bc('☵','kan')}${bc('☰','qian')}
</div></div>

<div class="card"><h3>⚖️ 五行天干流注</h3>
<div class="sgrid">
<div class="stat"><div class="sv" style="font-size:16px">${v.balance?.five_elements?.last_check||0}</div><div class="sl">五行检测</div></div>
<div class="stat"><div class="sv" style="font-size:16px">${v.balance?.stem_scheduler?.current_stem||'?'}</div><div class="sl">天干·${v.balance?.stem_scheduler?.element||''}</div></div>
<div class="stat"><div class="sv" style="font-size:13px">${v.balance?.meridian_rhythm?.current_meridian||'?'}</div><div class="sl">当前经络</div></div>
<div class="stat"><div class="sv" style="font-size:16px">${v.balance?.meridian_rhythm?.chinese_hour||''}时</div><div class="sl">时辰</div></div>
</div></div>`}catch(e){document.getElementById('mc').innerHTML='<div class="card"><h3>⚙️ 系统状态</h3><div class="empt">获取失败</div></div>'}}

// Silent auto-refresh (30s) — only update if data changed, no full re-render
setInterval(() => {
  if (ct === "status") rs();
  // upload/wiki/graph: only refresh if user hasn't interacted in last 60s
}, 30000);
lf();
</script>
</body>
