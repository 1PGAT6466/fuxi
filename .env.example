# ===========================
# 伏羲 Fuxi v1.50 环境变量配置
# 复制为 .env 后填写实际值
# cp .env.example .env
# ===========================
#
# 分组说明:
#   [安全]     - 认证、加密、访问控制
#   [LLM]      - 大语言模型 API
#   [服务]     - HTTP 服务与网络
#   [数据]     - 存储、向量库、目录
#   [知识库]   - 文档处理、分块、嵌入
#   [缓存]     - Redis 缓存层
#   [搜索]     - 外部搜索 API
#   [开发]     - 运行环境与日志
#   [代理]     - 外部代理服务

# ============================================
# [安全] 认证与安全配置
# ============================================

# JWT 签名密钥（生产环境必须设置！）
# 生成方法: openssl rand -hex 32 或 python -c "import secrets; print(secrets.token_hex(32))"
# 警告: 未设置时自动生成随机密钥，重启后所有 Token 失效
# 禁止使用弱密钥如 change-me, secret, jwt-secret 等
FUXI_JWT_SECRET=

# JWT Token 过期时间，单位小时
# 默认: 24
JWT_EXPIRY_HOURS=24

# 是否允许新用户注册（生产环境建议关闭）
# 可选值: true / false
# 默认: true
FUXI_ALLOW_REGISTRATION=true

# 管理员 API Token，用于管理接口鉴权
# 生产环境务必修改
KB_ADMIN_TOKEN=change_me_in_production

# ============================================
# [LLM] 大语言模型配置
# ============================================

# MiMo LLM API 密钥（主模型，必填）
MIMO_API_KEY=

# MiMo API 基础地址
# 默认: https://token-plan-cn.xiaomimimo.com/v1
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# MiMo 模型名称
# 默认: mimo-v2.5
MIMO_MODEL=mimo-v2.5

# MiMo API 请求超时，单位秒
# 默认: 60
MIMO_TIMEOUT=60

# DeepSeek API 密钥（Rerank 降级备用）
DEEPSEEK_API_KEY=

# DeepSeek API 基础地址
# 默认: https://api.deepseek.com
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DeepSeek 模型名称
# 默认: deepseek-v4-pro
DEEPSEEK_MODEL=deepseek-v4-pro

# DeepSeek API 请求超时，单位秒
# 默认: 60
DEEPSEEK_TIMEOUT=60

# SiliconFlow API 密钥（Rerank 首选）
SILICONFLOW_API_KEY=

# SiliconFlow API 基础地址
# 默认: https://api.siliconflow.cn/v1
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# OpenAI API 密钥（L1 降级第三重试 — 4o-mini）
# 当 MiMo 和 DeepSeek 全不可用时，降级到 4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT=30

# Token 会话预算（v1.50 方案第13条：硬上限 ¥0.15）
# 每个会话的累计 LLM 调用成本上限，超过则触发熔断
# 默认 0.15（人民币元）
FUXI_SESSION_BUDGET=0.15

# ============================================
# [服务] HTTP 服务与网络
# ============================================

# 服务监听地址
# 默认: 0.0.0.0（监听所有网络接口）
KB_HOST=0.0.0.0

# 服务监听端口
# 默认: 8080
KB_PORT=8080

# CORS 允许的来源域名，多个用英文逗号分隔
# 默认自动包含 localhost:8080 和 127.0.0.1:8080
KB_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# API 请求 AI 超时，单位秒
# 默认: 30
KB_AI_TIMEOUT=30

# 文件上传大小上限，单位 MB
# 默认: 200
KB_UPLOAD_MAX_MB=200

# ============================================
# [数据] 存储与目录
# ============================================

# 数据根目录（相对于项目根或绝对路径）
# 默认: data
FUXI_DATA_DIR=data

# ============================================
# [知识库] 文档处理与向量存储
# ============================================

# Embedder 服务地址
# 默认: http://localhost:8081
KB_EMBEDDER_URL=http://localhost:8081

# Rerank 代理地址（用于 Bi-Encoder 精排降级）
# 默认留空则不使用
KB_RERANK_PROXY=

# Embedder Worker 数量
# 默认: 4
KB_EMBEDDER_WORKERS=4

# ChromaDB 向量数据库持久化目录
# 默认: data/chromadb（相对于 FUXI_DATA_DIR）
KB_CHROMA_DIR=data/chromadb

# 知识库默认模型名称（用于嵌入/检索）
# 默认: text-embedding-3-small
KB_MODEL=BAAI/bge-large-zh-v1.5

# 文档分块大小（字符数）
# 默认: 1000
CHUNK_SIZE=1000

# 文档分块重叠大小（字符数）
# 默认: 100
CHUNK_OVERLAP=100

# 单文件上传大小上限，单位 MB（用于文档解析）
# 默认: 200
MAX_FILE_MB=200

# ============================================
# [缓存] Redis 缓存层
# ============================================

# Redis 连接 URL（可选，用于 L3 缓存层）
# 格式: redis://[:password@]host:port/db
# 示例: redis://localhost:6379/0
# 留空则禁用 Redis 缓存
REDIS_URL=

# Redis 任务队列配置（v1.44 Phase1 消息队列）
# Redis 服务器地址
# 默认: localhost
REDIS_HOST=localhost

# Redis 服务器端口
# 默认: 6379
REDIS_PORT=6379

# Redis 数据库编号
# 默认: 0
REDIS_DB=0

# Redis 密码（可选）
# 留空则无密码
REDIS_PASSWORD=

# Redis Stream 名称（用于任务队列）
# 默认: fuxi:tasks
REDIS_STREAM_NAME=fuxi:tasks

# Redis 消费者组名称
# 默认: fuxi:workers
REDIS_GROUP_NAME=fuxi:workers

# ============================================
# [搜索] 外部搜索 API
# ============================================

# Brave Search API 密钥（用于联网搜索增强）
# 获取地址: https://brave.com/search/api/
# 可选，留空则禁用联网搜索
BRAVE_API_KEY=

# ============================================
# [代理] 外部代理服务
# ============================================

# 文档加载器服务地址
# 默认: http://127.0.0.1:8090
LOADER_URL=http://127.0.0.1:8090

# Rerank 代理服务地址
# 默认: http://127.0.0.1:8091
KB_RERANK_PROXY=http://127.0.0.1:8091

# ============================================
# [开发] 运行环境与日志
# ============================================

# 运行环境
# 可选值: development / production / testing
# 默认: development
FUXI_ENV=development

# 日志级别
# 可选值: DEBUG / INFO / WARNING / ERROR / CRITICAL
# 默认: INFO（生产环境建议 WARNING）
FUXI_LOG_LEVEL=INFO
